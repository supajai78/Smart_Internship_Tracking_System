<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | ' : '' %>Smart Internship
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="min-h-screen bg-white text-gray-900 font-sans">
    <!-- Flash Messages Modal -->
    <% if (typeof error_msg !=='undefined' && error_msg && error_msg.length> 0) { %>
        <div id="alertModal" class="modal-overlay" onclick="closeModal(event)">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="p-6 text-center">
                    <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 flex items-center justify-center">
                        <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">เกิดข้อผิดพลาด</h3>
                    <p class="text-gray-600">
                        <%= error_msg %>
                    </p>
                </div>
                <div class="px-6 pb-6">
                    <button onclick="closeModalBtn()" class="btn btn-danger w-full">ตกลง</button>
                </div>
            </div>
        </div>
        <% } %>

            <%- body %>

                <script>
                    function closeModal(e) {
                        if (e.target.classList.contains('modal-overlay')) {
                            document.getElementById('alertModal').remove();
                        }
                    }

                    function closeModalBtn() {
                        const modal = document.getElementById('alertModal');
                        if (modal) modal.remove();
                    }
                </script>
</body>

</html>