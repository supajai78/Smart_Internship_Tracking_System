<div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">ลงเวลาปฏิบัติงาน</h1>
        <% if (company) { %>
            <span class="text-sm text-gray-500">📍 <%= company.name %></span>
            <% } %>
    </div>

    <!-- Today Status -->
    <div class="card">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">📅 สถานะวันนี้</h3>
        <div class="grid md:grid-cols-2 gap-6">
            <!-- Check-in -->
            <div
                class="text-center p-6 rounded-lg <%= todayAttendance && todayAttendance.checkInTime ? 'bg-green-50' : 'bg-gray-50' %>">
                <% if (todayAttendance && todayAttendance.checkInTime) { %>
                    <span class="text-4xl">✅</span>
                    <p class="text-lg font-bold text-green-600 mt-2">เข้างานแล้ว</p>
                    <p class="text-2xl font-bold text-gray-800 mt-1">
                        <%= new Date(todayAttendance.checkInTime).toLocaleTimeString('th-TH', { hour: '2-digit' ,
                            minute: '2-digit' }) %> น.
                    </p>
                    <p class="text-sm text-gray-500 mt-1">
                        <%= todayAttendance.checkInMethod==='gps' ? '📍 GPS' : '📱 QR Code' %>
                    </p>
                    <% } else { %>
                        <span class="text-4xl">⏰</span>
                        <p class="text-lg font-bold text-gray-500 mt-2">ยังไม่เข้างาน</p>
                        <button onclick="checkIn()" class="btn btn-primary mt-4" id="checkInBtn">
                            📍 ลงเวลาเข้างาน (GPS)
                        </button>
                        <% } %>
            </div>

            <!-- Check-out -->
            <div
                class="text-center p-6 rounded-lg <%= todayAttendance && todayAttendance.checkOutTime ? 'bg-green-50' : 'bg-gray-50' %>">
                <% if (todayAttendance && todayAttendance.checkOutTime) { %>
                    <span class="text-4xl">✅</span>
                    <p class="text-lg font-bold text-green-600 mt-2">ออกงานแล้ว</p>
                    <p class="text-2xl font-bold text-gray-800 mt-1">
                        <%= new Date(todayAttendance.checkOutTime).toLocaleTimeString('th-TH', { hour: '2-digit' ,
                            minute: '2-digit' }) %> น.
                    </p>
                    <% } else if (todayAttendance && todayAttendance.checkInTime) { %>
                        <span class="text-4xl">🏃</span>
                        <p class="text-lg font-bold text-gray-500 mt-2">ยังไม่ออกงาน</p>
                        <button onclick="checkOut()" class="btn btn-secondary mt-4" id="checkOutBtn">
                            📍 ลงเวลาออกงาน (GPS)
                        </button>
                        <% } else { %>
                            <span class="text-4xl">⏳</span>
                            <p class="text-lg font-bold text-gray-400 mt-2">รอลงเวลาเข้างานก่อน</p>
                            <% } %>
            </div>
        </div>
    </div>

    <!-- Location Status -->
    <div class="card" id="locationStatus">
        <h3 class="text-lg font-semibold text-gray-800 mb-2">📍 ตำแหน่งของคุณ</h3>
        <p class="text-gray-500" id="locationText">กำลังตรวจสอบตำแหน่ง...</p>
        <div id="distanceInfo" class="hidden mt-2">
            <p class="text-sm">ระยะห่างจากสถานประกอบการ: <span id="distanceValue" class="font-bold"></span> เมตร</p>
            <p class="text-xs text-gray-500">อนุญาตภายในระยะ: <%= company ? company.checkInRadius : 500 %> เมตร</p>
        </div>
    </div>

    <!-- Map -->
    <% if (company) { %>
        <div class="card">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">🗺️ แผนที่</h3>
            <div id="map" style="height: 300px; border-radius: 0.5rem;"></div>
        </div>
        <% } %>

            <!-- History -->
            <div class="card">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">📋 ประวัติการลงเวลา</h3>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="text-left border-b">
                                <th class="pb-3 text-gray-600">วันที่</th>
                                <th class="pb-3 text-gray-600">เข้างาน</th>
                                <th class="pb-3 text-gray-600">ออกงาน</th>
                                <th class="pb-3 text-gray-600">สถานะ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (attendanceHistory.length===0) { %>
                                <tr>
                                    <td colspan="4" class="py-8 text-center text-gray-500">ยังไม่มีประวัติ</td>
                                </tr>
                                <% } %>
                                    <% attendanceHistory.forEach(a=> { %>
                                        <tr class="border-b">
                                            <td class="py-3">
                                                <%= new Date(a.date).toLocaleDateString('th-TH') %>
                                            </td>
                                            <td class="py-3">
                                                <% if (a.checkInTime) { %>
                                                    <%= new Date(a.checkInTime).toLocaleTimeString('th-TH', {
                                                        hour: '2-digit' , minute: '2-digit' }) %>
                                                        <% } else { %>
                                                            -
                                                            <% } %>
                                            </td>
                                            <td class="py-3">
                                                <% if (a.checkOutTime) { %>
                                                    <%= new Date(a.checkOutTime).toLocaleTimeString('th-TH', {
                                                        hour: '2-digit' , minute: '2-digit' }) %>
                                                        <% } else { %>
                                                            -
                                                            <% } %>
                                            </td>
                                            <td class="py-3">
                                                <% if (a.status==='present' ) { %>
                                                    <span class="status-badge status-success">เข้างาน</span>
                                                    <% } else if (a.status==='late' ) { %>
                                                        <span
                                                            class="status-badge bg-yellow-100 text-yellow-700">สาย</span>
                                                        <% } else if (a.status==='leave' ) { %>
                                                            <span class="status-badge status-pending">ลา</span>
                                                            <% } else { %>
                                                                <span
                                                                    class="status-badge bg-red-100 text-red-700">ขาด</span>
                                                                <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
</div>

<script>
    let userLat, userLng;
    const companyLat = <%= company ?company.latitude: 0 %>;
    const companyLng = <%= company ?company.longitude: 0 %>;
    const checkInRadius = <%= company ?company.checkInRadius: 500 %>;
    let map, userMarker, companyMarker, radiusCircle;

  // Initialize map
  <% if (company) { %>
        document.addEventListener('DOMContentLoaded', function () {
            map = L.map('map').setView([companyLat, companyLng], 16);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap'
            }).addTo(map);

            // Company marker
            companyMarker = L.marker([companyLat, companyLng]).addTo(map)
                .bindPopup('<%= company.name %>');

            // Radius circle
            radiusCircle = L.circle([companyLat, companyLng], {
                radius: checkInRadius,
                color: '#3B82F6',
                fillColor: '#3B82F6',
                fillOpacity: 0.1
            }).addTo(map);

            // Get user location
            getCurrentLocation();
        });
  <% } %>

        function getCurrentLocation() {
            if (!navigator.geolocation) {
                document.getElementById('locationText').textContent = 'เบราว์เซอร์ไม่รองรับ GPS';
                return;
            }

            navigator.geolocation.getCurrentPosition(
                function (position) {
                    userLat = position.coords.latitude;
                    userLng = position.coords.longitude;

                    const distance = calculateDistance(userLat, userLng, companyLat, companyLng);

                    document.getElementById('locationText').textContent =
                        `ละติจูด: ${userLat.toFixed(6)}, ลองจิจูด: ${userLng.toFixed(6)}`;
                    document.getElementById('distanceInfo').classList.remove('hidden');
                    document.getElementById('distanceValue').textContent = Math.round(distance);

                    // Update map
                    if (map) {
                        if (userMarker) {
                            userMarker.setLatLng([userLat, userLng]);
                        } else {
                            userMarker = L.marker([userLat, userLng], {
                                icon: L.divIcon({
                                    className: 'custom-div-icon',
                                    html: '<div style="background: #EF4444; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white;"></div>',
                                    iconSize: [12, 12]
                                })
                            }).addTo(map).bindPopup('ตำแหน่งของคุณ');
                        }

                        // Fit bounds
                        const bounds = L.latLngBounds([
                            [userLat, userLng],
                            [companyLat, companyLng]
                        ]);
                        map.fitBounds(bounds, { padding: [50, 50] });
                    }

                    // Check if within range
                    if (distance <= checkInRadius) {
                        document.getElementById('distanceValue').classList.add('text-green-600');
                    } else {
                        document.getElementById('distanceValue').classList.add('text-red-600');
                    }
                },
                function (error) {
                    document.getElementById('locationText').textContent = 'ไม่สามารถระบุตำแหน่งได้: ' + error.message;
                },
                { enableHighAccuracy: true }
            );
        }

    function calculateDistance(lat1, lon1, lat2, lon2) {
        const R = 6371e3;
        const φ1 = lat1 * Math.PI / 180;
        const φ2 = lat2 * Math.PI / 180;
        const Δφ = (lat2 - lat1) * Math.PI / 180;
        const Δλ = (lon2 - lon1) * Math.PI / 180;
        const a = Math.sin(Δφ / 2) * Math.sin(Δφ / 2) +
            Math.cos(φ1) * Math.cos(φ2) *
            Math.sin(Δλ / 2) * Math.sin(Δλ / 2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c;
    }

    async function checkIn() {
        const btn = document.getElementById('checkInBtn');
        btn.disabled = true;
        btn.textContent = 'กำลังลงเวลา...';

        if (!userLat || !userLng) {
            alert('ไม่สามารถระบุตำแหน่งได้');
            btn.disabled = false;
            btn.textContent = '📍 ลงเวลาเข้างาน (GPS)';
            return;
        }

        try {
            const response = await fetch('/student/attendance/checkin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ latitude: userLat, longitude: userLng, method: 'gps' })
            });
            const data = await response.json();

            if (data.success) {
                alert(data.message + ' เวลา: ' + data.time);
                location.reload();
            } else {
                alert(data.message);
                btn.disabled = false;
                btn.textContent = '📍 ลงเวลาเข้างาน (GPS)';
            }
        } catch (error) {
            alert('เกิดข้อผิดพลาด');
            btn.disabled = false;
            btn.textContent = '📍 ลงเวลาเข้างาน (GPS)';
        }
    }

    async function checkOut() {
        const btn = document.getElementById('checkOutBtn');
        btn.disabled = true;
        btn.textContent = 'กำลังลงเวลา...';

        if (!userLat || !userLng) {
            alert('ไม่สามารถระบุตำแหน่งได้');
            btn.disabled = false;
            btn.textContent = '📍 ลงเวลาออกงาน (GPS)';
            return;
        }

        try {
            const response = await fetch('/student/attendance/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ latitude: userLat, longitude: userLng, method: 'gps' })
            });
            const data = await response.json();

            if (data.success) {
                alert(data.message + ' เวลา: ' + data.time);
                location.reload();
            } else {
                alert(data.message);
                btn.disabled = false;
                btn.textContent = '📍 ลงเวลาออกงาน (GPS)';
            }
        } catch (error) {
            alert('เกิดข้อผิดพลาด');
            btn.disabled = false;
            btn.textContent = '📍 ลงเวลาออกงาน (GPS)';
        }
    }

    // Refresh location every 10 seconds
    setInterval(getCurrentLocation, 10000);
</script>