<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="/student/daily-logs" class="text-gray-500 hover:text-gray-700">← กลับ</a>
        <h1 class="text-2xl font-bold text-gray-800">แก้ไขบันทึก</h1>
    </div>

    <div class="card max-w-2xl">
        <form action="/student/daily-logs/<%= dailyLog._id %>" method="POST" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">วันที่</label>
                    <input type="date" class="input bg-gray-100"
                        value="<%= new Date(dailyLog.date).toISOString().split('T')[0] %>" disabled>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">จำนวนชั่วโมงทำงาน</label>
                    <input type="number" name="hoursWorked" class="input" value="<%= dailyLog.hoursWorked || 8 %>"
                        min="1" max="12">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">รายละเอียดงานที่ทำ *</label>
                <textarea name="workDescription" class="input" rows="8"
                    required><%= dailyLog.workDescription %></textarea>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="btn btn-primary">บันทึก</button>
                <a href="/student/daily-logs" class="btn btn-outline">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>