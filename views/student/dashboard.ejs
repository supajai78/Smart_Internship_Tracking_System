<div class="space-y-8 animate-fade-in">

    <!-- Welcome Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-6">
            <div class="w-20 h-20 rounded-3xl bg-white shadow-card p-1">
                <div
                    class="w-full h-full rounded-[20px] bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center text-white text-3xl font-bold">
                    <%= student.firstName.charAt(0) %>
                </div>
            </div>
            <div>
                <h1 class="text-3xl font-display font-bold text-surface-900">สวัสดี, <%= student.firstName %>! 👋</h1>
                <% if (student.company) { %>
                    <p class="text-surface-500 font-medium mt-1 flex items-center gap-2">
                        <i data-feather="map-pin" class="w-4 h-4 text-primary-500"></i>
                        ฝึกงานที่ <span class="text-surface-900 font-bold">
                            <%= student.company.name %>
                        </span>
                    </p>
                    <% } else { %>
                        <p class="text-surface-500 font-medium mt-1 text-yellow-600">ยังไม่มีสถานที่ฝึกงาน</p>
                        <% } %>
            </div>
        </div>
        <div class="flex gap-3">
            <a href="/student/attendance" class="btn btn-primary btn-lg shadow-xl shadow-primary-500/20">
                <i data-feather="map-pin" class="w-5 h-5"></i>
                <span>ลงเวลาเข้างาน</span>
            </a>
        </div>
    </div>

    <!-- Main Progress Section -->
    <div class="relative overflow-hidden bg-surface-900 rounded-[2rem] p-8 md:p-12 text-white shadow-2xl">
        <!-- Abstract Background -->
        <div
            class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary-600 rounded-full blur-[120px] opacity-20 -translate-y-1/2 translate-x-1/3">
        </div>
        <div
            class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-blue-600 rounded-full blur-[100px] opacity-20 translate-y-1/3 -translate-x-1/3">
        </div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-2xl font-bold mb-2">ความคืบหน้าการฝึกงาน</h2>
                <p class="text-surface-400 mb-8">คุณทำได้ยอดเยี่ยมมาก! พยายามต่อไปเพื่อเป้าหมาย</p>

                <div class="flex items-end gap-4 mb-4">
                    <span class="text-6xl font-display font-bold text-white">
                        <%= stats.progress %>%
                    </span>
                    <span class="text-xl text-primary-400 font-medium mb-3">สำเร็จแล้ว</span>
                </div>

                <div class="w-full h-4 bg-surface-800 rounded-full overflow-hidden mb-4 border border-surface-700">
                    <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all duration-1000 ease-out shadow-[0_0_20px_rgba(244,63,94,0.5)]"
                        style="width: <%= stats.progress %>%"></div>
                </div>

                <p class="text-surface-400 text-sm font-medium">
                    เข้างานแล้ว <span class="text-white font-bold">
                        <%= stats.totalAttendance %>
                    </span> จาก <span class="text-white font-bold">
                        <%= stats.requiredDays %>
                    </span> วันที่ต้องการ
                </p>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <!-- Today Status Widget -->
                <div class="bg-white/5 backdrop-blur-lg border border-white/10 p-6 rounded-3xl">
                    <div
                        class="w-12 h-12 rounded-2xl <%= stats.todayAttendance ? 'bg-green-500/20 text-green-400' : 'bg-surface-700/50 text-surface-400' %> flex items-center justify-center mb-4">
                        <i data-feather="<%= stats.todayAttendance ? 'check-circle' : 'clock' %>" class="w-6 h-6"></i>
                    </div>
                    <p class="text-surface-400 text-sm font-bold uppercase tracking-wider mb-1">สถานะวันนี้</p>
                    <p class="text-xl font-bold <%= stats.todayAttendance ? 'text-green-400' : 'text-white' %>">
                        <%= stats.todayAttendance ? 'เข้างานแล้ว' : 'ยังไม่ลงเวลา' %>
                    </p>
                </div>

                <!-- Monthly Widget -->
                <div class="bg-white/5 backdrop-blur-lg border border-white/10 p-6 rounded-3xl">
                    <div
                        class="w-12 h-12 rounded-2xl bg-blue-500/20 text-blue-400 flex items-center justify-center mb-4">
                        <i data-feather="calendar" class="w-6 h-6"></i>
                    </div>
                    <p class="text-surface-400 text-sm font-bold uppercase tracking-wider mb-1">เดือนนี้</p>
                    <p class="text-xl font-bold text-white">
                        <%= stats.monthlyAttendance %> วัน
                    </p>
                </div>

                <!-- Logs Widget -->
                <div class="bg-white/5 backdrop-blur-lg border border-white/10 p-6 rounded-3xl">
                    <div
                        class="w-12 h-12 rounded-2xl bg-purple-500/20 text-purple-400 flex items-center justify-center mb-4">
                        <i data-feather="book" class="w-6 h-6"></i>
                    </div>
                    <p class="text-surface-400 text-sm font-bold uppercase tracking-wider mb-1">บันทึกงาน</p>
                    <p class="text-xl font-bold text-white">
                        <%= stats.totalDailyLogs %> ครั้ง
                    </p>
                </div>

                <!-- Leave Widget -->
                <div class="bg-white/5 backdrop-blur-lg border border-white/10 p-6 rounded-3xl">
                    <div
                        class="w-12 h-12 rounded-2xl bg-yellow-500/20 text-yellow-400 flex items-center justify-center mb-4">
                        <i data-feather="file-minus" class="w-6 h-6"></i>
                    </div>
                    <p class="text-surface-400 text-sm font-bold uppercase tracking-wider mb-1">ลารออนุมัติ</p>
                    <p class="text-xl font-bold text-white">
                        <%= stats.pendingLeaves %> ใบ
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Info Cards Grid -->
    <div class="grid md:grid-cols-2 gap-8">
        <!-- Company Info -->
        <% if (student.company) { %>
            <div class="card h-full">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-xl font-bold text-surface-900 flex items-center gap-2">
                        <i data-feather="briefcase" class="w-5 h-5 text-orange-500"></i>
                        สถานประกอบการ
                    </h3>
                </div>
                <div class="bg-surface-50 rounded-3xl p-6 border border-surface-100">
                    <div class="flex items-start gap-4">
                        <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-2xl shadow-sm">
                            🏭
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-surface-900 mb-1">
                                <%= student.company.name %>
                            </h4>
                            <p class="text-surface-500 text-sm leading-relaxed mb-4">
                                <%= student.company.address %>
                            </p>
                            <% if (student.company.phone) { %>
                                <div
                                    class="flex items-center gap-2 text-surface-600 font-medium bg-white px-3 py-2 rounded-xl inline-flex border border-surface-200">
                                    <i data-feather="phone" class="w-4 h-4"></i>
                                    <%= student.company.phone %>
                                </div>
                                <% } %>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>

                <!-- Teacher Info -->
                <% if (student.teacher) { %>
                    <div class="card h-full">
                        <div class="flex items-center justify-between mb-6">
                            <h3 class="text-xl font-bold text-surface-900 flex items-center gap-2">
                                <i data-feather="user" class="w-5 h-5 text-primary-500"></i>
                                ครูนิเทศก์
                            </h3>
                        </div>
                        <div class="bg-surface-50 rounded-3xl p-6 border border-surface-100">
                            <div class="flex items-center gap-5">
                                <div
                                    class="w-20 h-20 bg-gradient-to-br from-primary-100 to-primary-200 rounded-2xl flex items-center justify-center text-primary-600 text-2xl font-bold shadow-inner">
                                    <%= student.teacher.firstName.charAt(0) %>
                                </div>
                                <div>
                                    <h4 class="text-xl font-bold text-surface-900 mb-1">
                                        <%= student.teacher.firstName %>
                                            <%= student.teacher.lastName %>
                                    </h4>
                                    <p class="text-surface-500 text-sm mb-3">ครูประจำวิชาชีพ</p>
                                    <% if (student.teacher.email || student.teacher.phone) { %>
                                        <div class="flex flex-wrap gap-2 text-sm">
                                            <% if (student.teacher.phone) { %>
                                                <span
                                                    class="flex items-center gap-1 text-surface-600 bg-white px-2 py-1 rounded-lg border border-surface-200">
                                                    <i data-feather="phone" class="w-3 h-3"></i>
                                                    <%= student.teacher.phone %>
                                                </span>
                                                <% } %>
                                                    <% if (student.teacher.email) { %>
                                                        <span
                                                            class="flex items-center gap-1 text-surface-600 bg-white px-2 py-1 rounded-lg border border-surface-200">
                                                            <i data-feather="mail" class="w-3 h-3"></i> ติดต่อครู
                                                        </span>
                                                        <% } %>
                                        </div>
                                        <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
    </div>
</div>