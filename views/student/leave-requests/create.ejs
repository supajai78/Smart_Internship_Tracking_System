<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="/student/leave-requests" class="text-gray-500 hover:text-gray-700">← กลับ</a>
        <h1 class="text-2xl font-bold text-gray-800">ขอลางาน</h1>
    </div>

    <div class="card max-w-2xl">
        <form action="/student/leave-requests" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">ประเภทการลา *</label>
                <select name="type" class="input" required>
                    <option value="">-- เลือกประเภท --</option>
                    <option value="sick">🤒 ลาป่วย</option>
                    <option value="personal">📋 ลากิจ</option>
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">วันที่เริ่มลา *</label>
                    <input type="date" name="startDate" class="input" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">วันที่สิ้นสุด *</label>
                    <input type="date" name="endDate" class="input" required>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">เหตุผลการลา *</label>
                <textarea name="reason" class="input" rows="4" placeholder="ระบุเหตุผลการลา..." required></textarea>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="btn btn-primary">ส่งคำขอ</button>
                <a href="/student/leave-requests" class="btn btn-outline">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>