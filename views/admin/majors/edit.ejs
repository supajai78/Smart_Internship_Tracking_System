<div class="space-y-6 animate-fade-in">
    <!-- Header -->
    <div class="flex items-center gap-4">
        <a href="/admin/majors"
            class="p-2 rounded-xl bg-white border border-surface-200 text-surface-500 hover:text-primary-600 hover:border-primary-200 transition-all">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-surface-900">แก้ไขสาขาวิชา</h1>
            <p class="text-sm text-surface-500">
                <%= major.name %>
            </p>
        </div>
    </div>

    <div class="card max-w-2xl">
        <form action="/admin/majors/<%= major._id %>" method="POST" class="space-y-5">
            <div class="form-group">
                <label class="form-label">แผนกวิชา *</label>
                <select name="department" class="input" required>
                    <% departments.forEach(d=> { %>
                        <option value="<%= d._id %>" <%=major.department &&
                            major.department.toString()===d._id.toString() ? 'selected' : '' %>><%= d.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="form-group">
                    <label class="form-label">รหัสสาขา *</label>
                    <input type="text" name="code" class="input" value="<%= major.code %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label">ชื่อสาขาวิชา *</label>
                    <input type="text" name="name" class="input" value="<%= major.name %>" required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">รายละเอียด</label>
                <textarea name="description" class="input" rows="2"><%= major.description || '' %></textarea>
            </div>

            <div class="flex items-center gap-3 p-4 bg-surface-50 rounded-2xl">
                <input type="checkbox" name="isActive" id="isActive"
                    class="w-5 h-5 rounded border-surface-300 text-primary-600 focus:ring-primary-500" <%=major.isActive
                    ? 'checked' : '' %>>
                <label for="isActive" class="text-surface-700 font-medium">เปิดใช้งาน</label>
            </div>

            <div class="flex gap-3 pt-4 border-t border-surface-100">
                <button type="submit" class="btn btn-primary">
                    <i data-feather="save" class="w-4 h-4"></i>
                    บันทึก
                </button>
                <a href="/admin/majors" class="btn btn-secondary">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>