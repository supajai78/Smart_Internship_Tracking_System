<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">จัดการสถานประกอบการ</h1>
        <a href="/admin/companies/create" class="btn btn-primary">➕ เพิ่มสถานประกอบการ</a>
    </div>
    <div class="card">
        <table class="w-full">
            <thead>
                <tr class="text-left border-b">
                    <th class="pb-3 text-gray-600">ชื่อสถานประกอบการ</th>
                    <th class="pb-3 text-gray-600">ที่อยู่</th>
                    <th class="pb-3 text-gray-600">เบอร์โทร</th>
                    <th class="pb-3 text-gray-600">MOU</th>
                    <th class="pb-3 text-gray-600 text-right">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                <% companies.forEach(item=> { %>
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 font-medium">
                            <%= item.name %>
                        </td>
                        <td class="py-3 text-sm text-gray-500">
                            <%= item.address %>
                        </td>
                        <td class="py-3">
                            <%= item.phone || '-' %>
                        </td>
                        <td class="py-3">
                            <% if (item.isMOU) { %>
                                <span class="status-badge status-success">MOU</span>
                                <% } else { %>
                                    <span class="status-badge status-pending">ไม่มี</span>
                                    <% } %>
                        </td>
                        <td class="py-3 text-right">
                            <a href="/admin/companies/<%= item._id %>/edit"
                                class="text-primary-600 hover:text-primary-800 mr-3">แก้ไข</a>
                            <form action="/admin/companies/<%= item._id %>/delete" method="POST" class="inline"
                                onsubmit="return confirmDelete()">
                                <button type="submit" class="text-danger-500 hover:text-danger-700">ลบ</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </div>
</div>