<div class="space-y-6 animate-fade-in">
    <!-- Header -->
    <div class="flex items-center gap-4">
        <a href="/admin/companies"
            class="p-2 rounded-xl bg-white border border-surface-200 text-surface-500 hover:text-primary-600 hover:border-primary-200 transition-all">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-surface-900">แก้ไขสถานประกอบการ</h1>
            <p class="text-sm text-surface-500">
                <%= company.name %>
            </p>
        </div>
    </div>

    <form action="/admin/companies/<%= company._id %>" method="POST" class="grid lg:grid-cols-2 gap-6">
        <!-- Left Column: Form -->
        <div class="card space-y-5">
            <h3 class="text-lg font-bold text-surface-900 flex items-center gap-2 pb-4 border-b border-surface-100">
                <i data-feather="briefcase" class="w-5 h-5 text-primary-500"></i>
                ข้อมูลสถานประกอบการ
            </h3>

            <div class="form-group">
                <label class="form-label">ชื่อสถานประกอบการ *</label>
                <input type="text" name="name" class="input" value="<%= company.name %>" required>
            </div>

            <div class="form-group">
                <label class="form-label">ที่อยู่ *</label>
                <textarea name="address" class="input" rows="2" required><%= company.address %></textarea>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="form-group">
                    <label class="form-label">เบอร์โทร</label>
                    <input type="text" name="phone" class="input" value="<%= company.phone || '' %>">
                </div>
                <div class="form-group">
                    <label class="form-label">อีเมล</label>
                    <input type="email" name="email" class="input" value="<%= company.email || '' %>">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="form-group">
                    <label class="form-label">ผู้ติดต่อ</label>
                    <input type="text" name="contactPerson" class="input" value="<%= company.contactPerson || '' %>">
                </div>
                <div class="form-group">
                    <label class="form-label">เบอร์ผู้ติดต่อ</label>
                    <input type="text" name="contactPhone" class="input" value="<%= company.contactPhone || '' %>">
                </div>
            </div>

            <div class="flex items-center gap-3 p-4 bg-surface-50 rounded-2xl">
                <input type="checkbox" name="isMOU" id="isMOU"
                    class="w-5 h-5 rounded border-surface-300 text-primary-600 focus:ring-primary-500" <%=company.isMOU
                    ? 'checked' : '' %>>
                <label for="isMOU" class="text-surface-700 font-medium">เป็นสถานประกอบการ MOU</label>
            </div>
        </div>

        <!-- Right Column: Map -->
        <div class="card space-y-5">
            <h3 class="text-lg font-bold text-surface-900 flex items-center gap-2 pb-4 border-b border-surface-100">
                <i data-feather="map-pin" class="w-5 h-5 text-primary-500"></i>
                📍 ตำแหน่ง GPS (สำหรับ Check-in)
            </h3>

            <!-- Map Container -->
            <div class="relative">
                <div id="locationMap" class="w-full h-80 rounded-2xl border border-surface-200 bg-surface-100 z-0">
                </div>
                <div class="absolute top-3 right-3 z-10">
                    <button type="button" onclick="getCurrentLocation()"
                        class="p-3 bg-white rounded-xl shadow-lg border border-surface-200 text-primary-600 hover:bg-primary-50 transition-all"
                        title="ใช้ตำแหน่งปัจจุบัน">
                        <i data-feather="crosshair" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>

            <p class="text-sm text-surface-500 text-center">
                <i data-feather="info" class="w-4 h-4 inline"></i>
                ลากหมุดหรือคลิกบนแผนที่เพื่อเปลี่ยนตำแหน่ง
            </p>

            <!-- Coordinates Display -->
            <div class="grid grid-cols-3 gap-3">
                <div class="form-group">
                    <label class="form-label text-xs">ละติจูด</label>
                    <input type="number" step="any" name="latitude" id="latitude"
                        class="input text-center bg-surface-50" value="<%= company.latitude %>" required readonly>
                </div>
                <div class="form-group">
                    <label class="form-label text-xs">ลองจิจูด</label>
                    <input type="number" step="any" name="longitude" id="longitude"
                        class="input text-center bg-surface-50" value="<%= company.longitude %>" required readonly>
                </div>
                <div class="form-group">
                    <label class="form-label text-xs">ระยะ Check-in (ม.)</label>
                    <input type="number" name="checkInRadius" id="checkInRadius" class="input text-center"
                        value="<%= company.checkInRadius || 500 %>" min="100" max="2000">
                </div>
            </div>
        </div>

        <!-- Submit Buttons -->
        <div class="lg:col-span-2 flex gap-4">
            <button type="submit" class="btn btn-primary btn-lg shadow-xl shadow-primary-500/20">
                <i data-feather="save" class="w-5 h-5"></i>
                บันทึกการแก้ไข
            </button>
            <a href="/admin/companies" class="btn btn-secondary btn-lg">ยกเลิก</a>
        </div>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const existingLat = <%= company.latitude || 15.87 %>;
        const existingLng = <%= company.longitude || 100.9925 %>;
        const existingRadius = <%= company.checkInRadius || 500 %>;

        const map = L.map('locationMap').setView([existingLat, existingLng], 16);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        let marker = L.marker([existingLat, existingLng], { draggable: true }).addTo(map);
        let circle = L.circle([existingLat, existingLng], {
            radius: existingRadius,
            color: '#e11d48',
            fillColor: '#e11d48',
            fillOpacity: 0.2
        }).addTo(map);

        function updatePosition(lat, lng) {
            const radius = parseInt(document.getElementById('checkInRadius').value) || 500;
            marker.setLatLng([lat, lng]);
            circle.setLatLng([lat, lng]);
            circle.setRadius(radius);
            document.getElementById('latitude').value = lat.toFixed(6);
            document.getElementById('longitude').value = lng.toFixed(6);
        }

        marker.on('dragend', function (e) {
            const pos = e.target.getLatLng();
            updatePosition(pos.lat, pos.lng);
        });

        map.on('click', function (e) {
            updatePosition(e.latlng.lat, e.latlng.lng);
            map.setView([e.latlng.lat, e.latlng.lng], 16);
        });

        document.getElementById('checkInRadius').addEventListener('change', function () {
            circle.setRadius(parseInt(this.value) || 500);
        });

        window.getCurrentLocation = function () {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    function (position) {
                        updatePosition(position.coords.latitude, position.coords.longitude);
                        map.setView([position.coords.latitude, position.coords.longitude], 16);
                    },
                    function (error) {
                        alert('ไม่สามารถดึงตำแหน่งได้: ' + error.message);
                    }
                );
            } else {
                alert('Browser ไม่รองรับ Geolocation');
            }
        };
    });
</script>