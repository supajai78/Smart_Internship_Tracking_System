<div class="space-y-8">

    <!-- Welcome Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">สวัสดี, Admin! 👋</h1>
            <p class="text-slate-500">ภาพรวมระบบฝึกงาน ประจำปีการศึกษา <%= activeYear ? activeYear.name : '-' %>
            </p>
        </div>
        <div class="flex gap-3">
            <a href="/admin/users/create" class="btn btn-primary">
                <i data-feather="user-plus" class="w-4 h-4"></i>
                เพิ่มผู้ใช้
            </a>
            <a href="/admin/companies/create" class="btn btn-secondary">
                <i data-feather="briefcase" class="w-4 h-4"></i>
                เพิ่มสถานประกอบการ
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Students -->
        <div class="widget">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">นักศึกษา</p>
                    <p class="text-3xl font-bold text-slate-900 mt-1">
                        <%= stats.studentCount %>
                    </p>
                </div>
                <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center">
                    <i data-feather="users" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <!-- Teachers -->
        <div class="widget">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">ครูนิเทศก์</p>
                    <p class="text-3xl font-bold text-slate-900 mt-1">
                        <%= stats.teacherCount %>
                    </p>
                </div>
                <div class="w-12 h-12 rounded-xl bg-purple-50 text-purple-500 flex items-center justify-center">
                    <i data-feather="briefcase" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <!-- Companies -->
        <div class="widget">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">สถานประกอบการ</p>
                    <p class="text-3xl font-bold text-slate-900 mt-1">
                        <%= stats.companyCount %>
                    </p>
                </div>
                <div class="w-12 h-12 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center">
                    <i data-feather="map-pin" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <!-- Today Attendance -->
        <div class="widget bg-primary-50 border-primary-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide">เข้างานวันนี้</p>
                    <p class="text-3xl font-bold text-primary-700 mt-1">
                        <%= stats.todayAttendance %>
                    </p>
                </div>
                <div class="w-12 h-12 rounded-xl bg-primary-100 text-primary-600 flex items-center justify-center">
                    <i data-feather="clock" class="w-6 h-6"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="grid lg:grid-cols-3 gap-6">
        <!-- Main Chart -->
        <div class="lg:col-span-2 card">
            <div class="flex items-center justify-between mb-6">
                <h3 class="font-bold text-slate-900">นักศึกษาแยกตามแผนก</h3>
            </div>
            <div id="deptChart" class="h-72"></div>
        </div>

        <!-- Status Chart -->
        <div class="card">
            <h3 class="font-bold text-slate-900 mb-6">สถานะการฝึกงาน</h3>
            <div id="statusChart" class="h-56"></div>
            <div class="mt-4 space-y-2">
                <% chartData.internshipStatus.forEach((item, index)=> { %>
                    <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-slate-50">
                        <span class="text-sm text-slate-600">
                            <%= item.name %>
                        </span>
                        <span class="font-bold text-slate-900">
                            <%= item.count %>
                        </span>
                    </div>
                    <% }); %>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="grid md:grid-cols-3 gap-4">
        <a href="/admin/users" class="card hover:border-primary-200 group">
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i data-feather="users" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="font-semibold text-slate-900">จัดการผู้ใช้</p>
                    <p class="text-sm text-slate-400">Manage all users</p>
                </div>
            </div>
        </a>
        <a href="/admin/companies" class="card hover:border-primary-200 group">
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i data-feather="map-pin" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="font-semibold text-slate-900">สถานประกอบการ</p>
                    <p class="text-sm text-slate-400">Manage companies</p>
                </div>
            </div>
        </a>
        <a href="/admin/academic-years" class="card hover:border-primary-200 group">
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-xl bg-green-50 text-green-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i data-feather="calendar" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="font-semibold text-slate-900">ปีการศึกษา</p>
                    <p class="text-sm text-slate-400">Academic calendar</p>
                </div>
            </div>
        </a>
    </div>

</div>

<!-- Charts Script -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var deptData = JSON.parse('<%- JSON.stringify(chartData.studentByDept).replace(/\x27/g, "\x5c\x27") %>');
        var statusData = JSON.parse('<%- JSON.stringify(chartData.internshipStatus).replace(/\x27/g, "\x5c\x27") %>');

        // Bar Chart
        new ApexCharts(document.querySelector("#deptChart"), {
            series: [{ name: 'Students', data: deptData.map(d => d.count) }],
            chart: { type: 'bar', height: 280, toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
            plotOptions: { bar: { borderRadius: 6, columnWidth: '45%', distributed: true } },
            dataLabels: { enabled: false },
            legend: { show: false },
            grid: { borderColor: '#f1f5f9', strokeDashArray: 4 },
            xaxis: {
                categories: deptData.map(d => d.name),
                labels: { style: { colors: '#94a3b8', fontSize: '11px' } },
                axisBorder: { show: false },
                axisTicks: { show: false }
            },
            yaxis: { labels: { style: { colors: '#94a3b8', fontSize: '11px' } } },
            colors: ['#f43f5e', '#ec4899', '#8b5cf6', '#3b82f6', '#10b981'],
            tooltip: { theme: 'light' }
        }).render();

        // Donut Chart
        new ApexCharts(document.querySelector("#statusChart"), {
            series: statusData.map(d => d.count),
            chart: { type: 'donut', height: 220, fontFamily: 'Inter, sans-serif' },
            labels: statusData.map(d => d.name),
            colors: ['#22c55e', '#fbbf24', '#94a3b8'],
            plotOptions: { pie: { donut: { size: '70%' } } },
            dataLabels: { enabled: false },
            legend: { show: false },
            stroke: { width: 2, colors: ['#fff'] }
        }).render();
    });
</script>