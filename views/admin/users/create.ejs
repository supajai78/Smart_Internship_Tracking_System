<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-4">
        <a href="/admin/users"
            class="p-2 rounded-lg bg-white border border-slate-200 text-slate-500 hover:text-slate-700 transition-colors">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-900">เพิ่มผู้ใช้</h1>
            <p class="text-sm text-slate-500">กรอกข้อมูลผู้ใช้ใหม่</p>
        </div>
    </div>

    <!-- Form -->
    <div class="card max-w-3xl">
        <form action="/admin/users" method="POST" class="space-y-6">

            <!-- Step 1: Role -->
            <div class="p-4 bg-slate-50 rounded-xl border-2 border-slate-200">
                <label class="form-label text-primary-600">ขั้นตอนที่ 1: เลือกบทบาท *</label>
                <select name="role" id="roleSelect" class="input" required onchange="toggleFields()">
                    <option value="">-- เลือกบทบาท --</option>
                    <option value="admin">ผู้ดูแลระบบ</option>
                    <option value="teacher">ครูนิเทศก์</option>
                    <option value="mentor">พี่เลี้ยง</option>
                    <option value="student">นักศึกษา</option>
                </select>
            </div>

            <!-- Basic Info -->
            <div class="border-t pt-6">
                <h3 class="font-bold text-slate-800 mb-4">ข้อมูลพื้นฐาน</h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="form-label">ชื่อผู้ใช้ *</label>
                        <input type="text" name="username" class="input" required placeholder="username">
                    </div>
                    <div>
                        <label class="form-label">รหัสผ่าน *</label>
                        <input type="password" name="password" class="input" required minlength="6"
                            placeholder="อย่างน้อย 6 ตัว">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="form-label">ชื่อ *</label>
                        <input type="text" name="firstName" class="input" required>
                    </div>
                    <div>
                        <label class="form-label">นามสกุล *</label>
                        <input type="text" name="lastName" class="input" required>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="form-label">อีเมล</label>
                        <input type="email" name="email" class="input">
                    </div>
                    <div>
                        <label class="form-label">เบอร์โทร</label>
                        <input type="text" name="phone" class="input">
                    </div>
                </div>
            </div>

            <!-- Student Fields -->
            <div id="studentFields" class="hidden border-t pt-6">
                <h3 class="font-bold text-blue-600 mb-4">
                    <i data-feather="book-open" class="w-5 h-5 inline"></i>
                    ข้อมูลนักศึกษา
                </h3>

                <div class="mb-4">
                    <label class="form-label">เลขประจำตัวนักศึกษา</label>
                    <input type="text" name="studentId" class="input" placeholder="เช่น 68319033001">
                </div>

                <!-- Cascading Selection -->
                <div class="p-4 bg-blue-50 rounded-xl space-y-4">
                    <p class="text-sm font-semibold text-blue-700 mb-2">🎯 เลือกแผนก → สาขา → ห้อง (ตามลำดับ)</p>

                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <label class="form-label">1. แผนกวิชา</label>
                            <select name="department" id="studentDept" class="input" onchange="filterMajors('student')">
                                <option value="">-- เลือกแผนก --</option>
                                <% departments.forEach(function(d) { %>
                                    <option value="<%= d._id.toString() %>">
                                        <%= d.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">2. สาขาวิชา</label>
                            <select name="major" id="studentMajor" class="input" onchange="filterSections('student')">
                                <option value="">-- เลือกสาขา --</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">3. ห้องเรียน</label>
                            <select name="section" id="studentSection" class="input">
                                <option value="">-- เลือกห้อง --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="form-label">ระดับชั้น</label>
                        <select name="level" class="input">
                            <option value="">-- เลือก --</option>
                            <% levels.forEach(function(l) { %>
                                <option value="<%= l._id %>">
                                    <%= l.name %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">หลักสูตร</label>
                        <select name="curriculum" class="input">
                            <option value="">-- เลือก --</option>
                            <% curriculums.forEach(function(c) { %>
                                <option value="<%= c._id %>">
                                    <%= c.name %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="form-label">สถานประกอบการ</label>
                        <select name="company" class="input">
                            <option value="">-- เลือก --</option>
                            <% companies.forEach(function(c) { %>
                                <option value="<%= c._id %>">
                                    <%= c.name %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">ครูนิเทศก์</label>
                        <select name="teacher" class="input">
                            <option value="">-- เลือก --</option>
                            <% teachers.forEach(function(t) { %>
                                <option value="<%= t._id %>">
                                    <%= t.firstName %>
                                        <%= t.lastName %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Teacher Fields -->
            <div id="teacherFields" class="hidden border-t pt-6">
                <h3 class="font-bold text-green-600 mb-4">
                    <i data-feather="briefcase" class="w-5 h-5 inline"></i>
                    ข้อมูลครูนิเทศก์
                </h3>

                <div class="p-4 bg-green-50 rounded-xl space-y-4">
                    <p class="text-sm font-semibold text-green-700 mb-2">🎯 เลือกแผนก → สาขา → ห้อง (ตามลำดับ)</p>

                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <label class="form-label">1. แผนกวิชา</label>
                            <select name="department" id="teacherDept" class="input" onchange="filterMajors('teacher')">
                                <option value="">-- เลือกแผนก --</option>
                                <% departments.forEach(function(d) { %>
                                    <option value="<%= d._id.toString() %>">
                                        <%= d.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">2. สาขาวิชา</label>
                            <select name="major" id="teacherMajor" class="input" onchange="filterSections('teacher')">
                                <option value="">-- เลือกสาขา --</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">3. ห้องเรียน</label>
                            <select name="section" id="teacherSection" class="input">
                                <option value="">-- เลือกห้อง --</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mentor Fields -->
            <div id="mentorFields" class="hidden border-t pt-6">
                <h3 class="font-bold text-purple-600 mb-4">
                    <i data-feather="heart" class="w-5 h-5 inline"></i>
                    ข้อมูลพี่เลี้ยง
                </h3>
                <div>
                    <label class="form-label">สถานประกอบการ *</label>
                    <select name="company" class="input">
                        <option value="">-- เลือกสถานประกอบการ --</option>
                        <% companies.forEach(function(c) { %>
                            <option value="<%= c._id %>">
                                <%= c.name %>
                            </option>
                            <% }); %>
                    </select>
                </div>
            </div>

            <!-- Submit -->
            <div class="flex gap-3 pt-4 border-t">
                <button type="submit" class="btn btn-primary">
                    <i data-feather="save" class="w-4 h-4"></i>
                    บันทึก
                </button>
                <a href="/admin/users" class="btn btn-secondary">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>

<script>
    // Build majors data
    var majorsData = JSON.parse('<%- JSON.stringify(majors.map(function(m) { return { _id: m._id.toString(), name: m.name, department: m.department ? (m.department._id ? m.department._id.toString() : m.department.toString()) : "" }; })).replace(/\x27/g, "\x5c\x27") %>');

    // Build sections data  
    var sectionsData = JSON.parse('<%- JSON.stringify(sections.map(function(s) { return { _id: s._id.toString(), name: s.name, code: s.code, major: s.major ? (s.major._id ? s.major._id.toString() : s.major.toString()) : "" }; })).replace(/\x27/g, "\x5c\x27") %>');

    console.log('=== DEBUG INFO ===');
    console.log('Majors count:', majorsData.length);
    console.log('Sections count:', sectionsData.length);
    if (majorsData.length > 0) {
        console.log('Sample major:', majorsData[0]);
    }

    function toggleFields() {
        var role = document.getElementById('roleSelect').value;
        console.log('toggleFields - role:', role);

        document.getElementById('studentFields').classList.add('hidden');
        document.getElementById('teacherFields').classList.add('hidden');
        document.getElementById('mentorFields').classList.add('hidden');

        if (role === 'student') {
            document.getElementById('studentFields').classList.remove('hidden');
        } else if (role === 'teacher') {
            document.getElementById('teacherFields').classList.remove('hidden');
        } else if (role === 'mentor') {
            document.getElementById('mentorFields').classList.remove('hidden');
        }

        if (typeof feather !== 'undefined') {
            feather.replace();
        }
    }

    function filterMajors(prefix) {
        var deptSelect = document.getElementById(prefix + 'Dept');
        var majorSelect = document.getElementById(prefix + 'Major');
        var sectionSelect = document.getElementById(prefix + 'Section');
        var deptId = deptSelect.value;

        console.log('filterMajors - prefix:', prefix, 'deptId:', deptId);

        // Reset
        majorSelect.innerHTML = '<option value="">-- เลือกสาขา --</option>';
        sectionSelect.innerHTML = '<option value="">-- เลือกห้อง --</option>';

        if (!deptId) {
            console.log('No department selected, returning');
            return;
        }

        // Filter majors
        var filtered = [];
        for (var i = 0; i < majorsData.length; i++) {
            if (majorsData[i].department === deptId) {
                filtered.push(majorsData[i]);
            }
        }

        console.log('Filtered majors count:', filtered.length);

        // Add options
        for (var j = 0; j < filtered.length; j++) {
            var opt = document.createElement('option');
            opt.value = filtered[j]._id;
            opt.textContent = filtered[j].name;
            majorSelect.appendChild(opt);
        }
    }

    function filterSections(prefix) {
        var majorSelect = document.getElementById(prefix + 'Major');
        var sectionSelect = document.getElementById(prefix + 'Section');
        var majorId = majorSelect.value;

        console.log('filterSections - prefix:', prefix, 'majorId:', majorId);

        // Reset
        sectionSelect.innerHTML = '<option value="">-- เลือกห้อง --</option>';

        if (!majorId) {
            console.log('No major selected, returning');
            return;
        }

        // Filter sections
        var filtered = [];
        for (var i = 0; i < sectionsData.length; i++) {
            if (sectionsData[i].major === majorId) {
                filtered.push(sectionsData[i]);
            }
        }

        console.log('Filtered sections count:', filtered.length);

        // Add options
        for (var j = 0; j < filtered.length; j++) {
            var opt = document.createElement('option');
            opt.value = filtered[j]._id;
            opt.textContent = filtered[j].code + ' - ' + filtered[j].name;
            sectionSelect.appendChild(opt);
        }
    }
</script>