<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-4">
        <a href="/admin/users"
            class="p-2 rounded-lg bg-white border border-slate-200 text-slate-500 hover:text-slate-700 transition-colors">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-900">แก้ไขผู้ใช้</h1>
            <p class="text-sm text-slate-500">
                <%= editUser.firstName %>
                    <%= editUser.lastName %>
            </p>
        </div>
    </div>

    <!-- Form -->
    <div class="card max-w-3xl">
        <form action="/admin/users/<%= editUser._id %>" method="POST" class="space-y-6">

            <!-- Role Badge -->
            <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-xl">
                <span class="text-sm text-slate-600">บทบาท:</span>
                <% if (editUser.role==='admin' ) { %>
                    <span class="badge bg-slate-100 text-slate-700">ผู้ดูแลระบบ</span>
                    <% } else if (editUser.role==='student' ) { %>
                        <span class="badge bg-blue-100 text-blue-700">นักศึกษา</span>
                        <% } else if (editUser.role==='teacher' ) { %>
                            <span class="badge bg-green-100 text-green-700">ครูนิเทศก์</span>
                            <% } else if (editUser.role==='mentor' ) { %>
                                <span class="badge bg-purple-100 text-purple-700">พี่เลี้ยง</span>
                                <% } %>
                                    <input type="hidden" name="role" value="<%= editUser.role %>">
            </div>

            <!-- Basic Info -->
            <div class="border-t pt-6">
                <h3 class="font-bold text-slate-800 mb-4">ข้อมูลพื้นฐาน</h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="form-label">ชื่อผู้ใช้ *</label>
                        <input type="text" name="username" class="input" value="<%= editUser.username %>" required>
                    </div>
                    <div>
                        <label class="form-label">รหัสผ่านใหม่ <span
                                class="text-slate-400">(เว้นว่างถ้าไม่เปลี่ยน)</span></label>
                        <input type="password" name="password" class="input" minlength="6">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="form-label">ชื่อ *</label>
                        <input type="text" name="firstName" class="input" value="<%= editUser.firstName %>" required>
                    </div>
                    <div>
                        <label class="form-label">นามสกุล *</label>
                        <input type="text" name="lastName" class="input" value="<%= editUser.lastName %>" required>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="form-label">อีเมล</label>
                        <input type="email" name="email" class="input" value="<%= editUser.email || '' %>">
                    </div>
                    <div>
                        <label class="form-label">เบอร์โทร</label>
                        <input type="text" name="phone" class="input" value="<%= editUser.phone || '' %>">
                    </div>
                </div>
            </div>

            <% if (editUser.role==='student' ) { %>
                <!-- Student Fields -->
                <div class="border-t pt-6">
                    <h3 class="font-bold text-blue-600 mb-4">
                        <i data-feather="book-open" class="w-5 h-5 inline"></i>
                        ข้อมูลนักศึกษา
                    </h3>

                    <div class="mb-4">
                        <label class="form-label">เลขประจำตัวนักศึกษา</label>
                        <input type="text" name="studentId" class="input" value="<%= editUser.studentId || '' %>">
                    </div>

                    <!-- Cascading Selection -->
                    <div class="p-4 bg-blue-50 rounded-xl space-y-4">
                        <p class="text-sm font-semibold text-blue-700 mb-2">🎯 เลือกแผนก → สาขา → ห้อง (ตามลำดับ)</p>

                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <label class="form-label">1. แผนกวิชา</label>
                                <select name="department" id="studentDept" class="input"
                                    onchange="filterMajors('student')">
                                    <option value="">-- เลือกแผนก --</option>
                                    <% departments.forEach(d=> { %>
                                        <option value="<%= d._id %>" <%=editUser.department &&
                                            editUser.department.toString()===d._id.toString() ? 'selected' : '' %>><%=
                                                d.name %>
                                        </option>
                                        <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label">2. สาขาวิชา</label>
                                <select name="major" id="studentMajor" class="input"
                                    onchange="filterSections('student')">
                                    <option value="">-- เลือกสาขา --</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label">3. ห้องเรียน</label>
                                <select name="section" id="studentSection" class="input">
                                    <option value="">-- เลือกห้อง --</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mt-4">
                        <div>
                            <label class="form-label">ระดับชั้น</label>
                            <select name="level" class="input">
                                <option value="">-- เลือก --</option>
                                <% levels.forEach(l=> { %>
                                    <option value="<%= l._id %>" <%=editUser.level &&
                                        editUser.level.toString()===l._id.toString() ? 'selected' : '' %>><%= l.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">หลักสูตร</label>
                            <select name="curriculum" class="input">
                                <option value="">-- เลือก --</option>
                                <% curriculums.forEach(c=> { %>
                                    <option value="<%= c._id %>" <%=editUser.curriculum &&
                                        editUser.curriculum.toString()===c._id.toString() ? 'selected' : '' %>><%=
                                            c.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mt-4">
                        <div>
                            <label class="form-label">สถานประกอบการ</label>
                            <select name="company" class="input">
                                <option value="">-- เลือก --</option>
                                <% companies.forEach(c=> { %>
                                    <option value="<%= c._id %>" <%=editUser.company &&
                                        editUser.company.toString()===c._id.toString() ? 'selected' : '' %>><%= c.name
                                            %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">ครูนิเทศก์</label>
                            <select name="teacher" class="input">
                                <option value="">-- เลือก --</option>
                                <% teachers.forEach(t=> { %>
                                    <option value="<%= t._id %>" <%=editUser.teacher &&
                                        editUser.teacher.toString()===t._id.toString() ? 'selected' : '' %>><%=
                                            t.firstName %>
                                            <%= t.lastName %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                    </div>
                </div>
                <% } %>

                    <% if (editUser.role==='teacher' ) { %>
                        <!-- Teacher Fields -->
                        <div class="border-t pt-6">
                            <h3 class="font-bold text-green-600 mb-4">
                                <i data-feather="briefcase" class="w-5 h-5 inline"></i>
                                ข้อมูลครูนิเทศก์
                            </h3>

                            <div class="p-4 bg-green-50 rounded-xl space-y-4">
                                <p class="text-sm font-semibold text-green-700 mb-2">🎯 เลือกแผนก → สาขา → ห้อง
                                    (ตามลำดับ)</p>

                                <div class="grid grid-cols-3 gap-4">
                                    <div>
                                        <label class="form-label">1. แผนกวิชา</label>
                                        <select name="department" id="teacherDept" class="input"
                                            onchange="filterMajors('teacher')">
                                            <option value="">-- เลือกแผนก --</option>
                                            <% departments.forEach(d=> { %>
                                                <option value="<%= d._id %>" <%=editUser.department &&
                                                    editUser.department.toString()===d._id.toString() ? 'selected' : ''
                                                    %>><%= d.name %>
                                                </option>
                                                <% }); %>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label">2. สาขาวิชา</label>
                                        <select name="major" id="teacherMajor" class="input"
                                            onchange="filterSections('teacher')">
                                            <option value="">-- เลือกสาขา --</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label">3. ห้องเรียน</label>
                                        <select name="section" id="teacherSection" class="input">
                                            <option value="">-- เลือกห้อง --</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% } %>

                            <% if (editUser.role==='mentor' ) { %>
                                <!-- Mentor Fields -->
                                <div class="border-t pt-6">
                                    <h3 class="font-bold text-purple-600 mb-4">
                                        <i data-feather="heart" class="w-5 h-5 inline"></i>
                                        ข้อมูลพี่เลี้ยง
                                    </h3>
                                    <div>
                                        <label class="form-label">สถานประกอบการ</label>
                                        <select name="company" class="input">
                                            <option value="">-- เลือก --</option>
                                            <% companies.forEach(c=> { %>
                                                <option value="<%= c._id %>" <%=editUser.company &&
                                                    editUser.company.toString()===c._id.toString() ? 'selected' : '' %>>
                                                    <%= c.name %>
                                                </option>
                                                <% }); %>
                                        </select>
                                    </div>
                                </div>
                                <% } %>

                                    <!-- Submit -->
                                    <div class="flex gap-3 pt-4 border-t">
                                        <button type="submit" class="btn btn-primary">
                                            <i data-feather="save" class="w-4 h-4"></i>
                                            บันทึก
                                        </button>
                                        <a href="/admin/users" class="btn btn-secondary">ยกเลิก</a>
                                    </div>
        </form>
    </div>
</div>

<script>
    // Build majors data - using JSON.parse approach
    var majorsData = JSON.parse('<%- JSON.stringify(majors.map(function(m) { return { _id: m._id.toString(), name: m.name, department: m.department ? (m.department._id ? m.department._id.toString() : m.department.toString()) : "" }; })).replace(/\x27/g, "\x5c\x27") %>');

    // Build sections data
    var sectionsData = JSON.parse('<%- JSON.stringify(sections.map(function(s) { return { _id: s._id.toString(), name: s.name, code: s.code, major: s.major ? (s.major._id ? s.major._id.toString() : s.major.toString()) : "" }; })).replace(/\x27/g, "\x5c\x27") %>');

    // Current user data
    var currentMajorId = '<%= editUser.major ? editUser.major.toString() : "" %>';
    var currentSectionId = '<%= editUser.section ? editUser.section.toString() : "" %>';

    console.log('Edit form - Majors loaded:', majorsData.length);
    console.log('Edit form - Sections loaded:', sectionsData.length);

    // Initialize on load
    document.addEventListener('DOMContentLoaded', function () {
    <% if (editUser.role === 'student') { %>
      if (document.getElementById('studentDept') && document.getElementById('studentDept').value) {
                filterMajors('student', true);
            }
    <% } %>
    <% if (editUser.role === 'teacher') { %>
      if (document.getElementById('teacherDept') && document.getElementById('teacherDept').value) {
                filterMajors('teacher', true);
            }
    <% } %>
    if (typeof feather !== 'undefined') {
            feather.replace();
        }
    });

    function filterMajors(prefix, isInit) {
        isInit = isInit || false;
        var deptId = document.getElementById(prefix + 'Dept').value;
        var majorSelect = document.getElementById(prefix + 'Major');
        var sectionSelect = document.getElementById(prefix + 'Section');

        console.log('Edit filterMajors called, prefix:', prefix, 'deptId:', deptId);

        majorSelect.innerHTML = '<option value="">-- เลือกสาขา --</option>';
        sectionSelect.innerHTML = '<option value="">-- เลือกห้อง --</option>';

        if (!deptId) return;

        var filtered = [];
        for (var i = 0; i < majorsData.length; i++) {
            if (majorsData[i].department === deptId) {
                filtered.push(majorsData[i]);
            }
        }
        console.log('Edit Filtered majors:', filtered.length);

        for (var j = 0; j < filtered.length; j++) {
            var opt = document.createElement('option');
            opt.value = filtered[j]._id;
            opt.textContent = filtered[j].name;
            if (isInit && currentMajorId === filtered[j]._id) {
                opt.selected = true;
            }
            majorSelect.appendChild(opt);
        }

        if (isInit && currentMajorId) {
            filterSections(prefix, true);
        }
    }

    function filterSections(prefix, isInit) {
        isInit = isInit || false;
        var majorId = document.getElementById(prefix + 'Major').value;
        var sectionSelect = document.getElementById(prefix + 'Section');

        console.log('Edit filterSections called, prefix:', prefix, 'majorId:', majorId);

        sectionSelect.innerHTML = '<option value="">-- เลือกห้อง --</option>';

        if (!majorId) return;

        var filtered = [];
        for (var i = 0; i < sectionsData.length; i++) {
            if (sectionsData[i].major === majorId) {
                filtered.push(sectionsData[i]);
            }
        }
        console.log('Edit Filtered sections:', filtered.length);

        for (var j = 0; j < filtered.length; j++) {
            var opt = document.createElement('option');
            opt.value = filtered[j]._id;
            opt.textContent = filtered[j].code + ' - ' + filtered[j].name;
            if (isInit && currentSectionId === filtered[j]._id) {
                opt.selected = true;
            }
            sectionSelect.appendChild(opt);
        }
    }
</script>