<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">จัดการผู้ใช้งาน</h1>
            <p class="text-slate-500 text-sm">ทั้งหมด <%= users.length %> บัญชี</p>
        </div>
        <a href="/admin/users/create" class="btn btn-primary">
            <i data-feather="user-plus" class="w-4 h-4"></i>
            เพิ่มผู้ใช้
        </a>
    </div>

    <!-- Filters Section -->
    <div class="card p-4">
        <div class="flex flex-wrap items-center gap-4">
            <!-- Role Filter -->
            <div class="flex-1 min-w-[200px]">
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">บทบาท</label>
                <select id="roleFilter" class="input py-2" onchange="applyFilters()">
                    <option value="all">ทั้งหมด (<%= users.length %>)</option>
                    <option value="admin">ผู้ดูแล (<%= users.filter(u=> u.role === 'admin').length %>)</option>
                    <option value="teacher">ครูนิเทศก์ (<%= users.filter(u=> u.role === 'teacher').length %>)</option>
                    <option value="mentor">พี่เลี้ยง (<%= users.filter(u=> u.role === 'mentor').length %>)</option>
                    <option value="student">นักศึกษา (<%= users.filter(u=> u.role === 'student').length %>)</option>
                </select>
            </div>

            <!-- Department Filter -->
            <div class="flex-1 min-w-[200px]">
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">แผนกวิชา</label>
                <select id="deptFilter" class="input py-2" onchange="applyFilters()">
                    <option value="all">ทุกแผนก</option>
                    <% departments.forEach(d=> { %>
                        <option value="<%= d._id %>">
                            <%= d.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <!-- Company Filter (for Mentors) -->
            <div class="flex-1 min-w-[200px]">
                <label
                    class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1 block">สถานประกอบการ</label>
                <select id="companyFilter" class="input py-2" onchange="applyFilters()">
                    <option value="all">ทุกสถานประกอบการ</option>
                    <% companies.forEach(c=> { %>
                        <option value="<%= c._id %>">
                            <%= c.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <!-- Reset Button -->
            <div class="pt-5">
                <button onclick="resetFilters()" class="btn btn-secondary btn-sm">
                    <i data-feather="x" class="w-4 h-4"></i>
                    ล้าง
                </button>
            </div>
        </div>
    </div>

    <!-- Results Count -->
    <div class="flex items-center justify-between">
        <p class="text-sm text-slate-500">แสดง <span id="resultCount" class="font-bold text-slate-700">
                <%= users.length %>
            </span> รายการ</p>
    </div>

    <!-- Users Table -->
    <div class="table-container">
        <table class="w-full">
            <thead>
                <tr>
                    <th class="table-head">ชื่อ-นามสกุล</th>
                    <th class="table-head">ชื่อผู้ใช้</th>
                    <th class="table-head">บทบาท</th>
                    <th class="table-head">แผนก/สถานประกอบการ</th>
                    <th class="table-head">ห้อง</th>
                    <th class="table-head text-right">จัดการ</th>
                </tr>
            </thead>
            <tbody id="usersTableBody">
                <% users.forEach(u=> { %>
                    <tr class="table-row user-row" data-role="<%= u.role %>"
                        data-dept="<%= u.department ? u.department._id : '' %>"
                        data-company="<%= u.company ? u.company._id : '' %>">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-sm
                  <% if (u.role === 'admin') { %>bg-slate-100 text-slate-600<% } 
                     else if (u.role === 'teacher') { %>bg-green-100 text-green-600<% } 
                     else if (u.role === 'mentor') { %>bg-purple-100 text-purple-600<% } 
                     else { %>bg-blue-100 text-blue-600<% } %>">
                                    <%= u.firstName ? u.firstName.charAt(0) : 'U' %>
                                </div>
                                <div>
                                    <p class="font-medium text-slate-900">
                                        <%= u.firstName %>
                                            <%= u.lastName %>
                                    </p>
                                    <% if (u.studentId) { %>
                                        <p class="text-xs text-slate-400 font-mono">
                                            <%= u.studentId %>
                                        </p>
                                        <% } %>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="font-mono text-sm text-slate-600">
                                <%= u.username %>
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <% if (u.role==='admin' ) { %>
                                <span class="badge bg-slate-100 text-slate-700">ผู้ดูแลระบบ</span>
                                <% } else if (u.role==='student' ) { %>
                                    <span class="badge bg-blue-100 text-blue-700">นักศึกษา</span>
                                    <% } else if (u.role==='teacher' ) { %>
                                        <span class="badge bg-green-100 text-green-700">ครูนิเทศก์</span>
                                        <% } else if (u.role==='mentor' ) { %>
                                            <span class="badge bg-purple-100 text-purple-700">พี่เลี้ยง</span>
                                            <% } %>
                        </td>
                        <td class="px-6 py-4 text-sm">
                            <% if (u.department) { %>
                                <span class="text-slate-700">
                                    <%= u.department.name %>
                                </span>
                                <% } else if (u.company) { %>
                                    <span class="text-orange-600">
                                        <%= u.company.name %>
                                    </span>
                                    <% } else { %>
                                        <span class="text-slate-300">-</span>
                                        <% } %>
                        </td>
                        <td class="px-6 py-4 text-sm">
                            <% if (u.section) { %>
                                <span class="badge badge-pill bg-primary-50 text-primary-700">
                                    <%= u.section.name %>
                                </span>
                                <% } else { %>
                                    <span class="text-slate-300">-</span>
                                    <% } %>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="/admin/users/<%= u._id %>/edit"
                                    class="p-2 rounded-lg text-slate-400 hover:text-blue-600 hover:bg-blue-50 transition-colors">
                                    <i data-feather="edit-2" class="w-4 h-4"></i>
                                </a>
                                <% if (u._id.toString() !==user.id) { %>
                                    <form action="/admin/users/<%= u._id %>/delete" method="POST" class="inline"
                                        onsubmit="return confirmDelete('ลบผู้ใช้นี้?')">
                                        <button type="submit"
                                            class="p-2 rounded-lg text-slate-400 hover:text-red-600 hover:bg-red-50 transition-colors">
                                            <i data-feather="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </form>
                                    <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>

        <!-- Empty State -->
        <div id="emptyState" class="hidden py-12 text-center">
            <div
                class="w-16 h-16 rounded-full bg-slate-100 mx-auto flex items-center justify-center mb-4 text-slate-400">
                <i data-feather="search" class="w-8 h-8"></i>
            </div>
            <p class="text-slate-500 font-medium">ไม่พบข้อมูลที่ตรงกับเงื่อนไข</p>
        </div>
    </div>
</div>

<script>
    function applyFilters() {
        const role = document.getElementById('roleFilter').value;
        const dept = document.getElementById('deptFilter').value;
        const company = document.getElementById('companyFilter').value;

        let visibleCount = 0;

        document.querySelectorAll('.user-row').forEach(row => {
            const rowRole = row.dataset.role;
            const rowDept = row.dataset.dept;
            const rowCompany = row.dataset.company;

            let show = true;

            // Role filter
            if (role !== 'all' && rowRole !== role) {
                show = false;
            }

            // Department filter (for teacher/student)
            if (dept !== 'all' && rowDept !== dept) {
                show = false;
            }

            // Company filter (for mentor)
            if (company !== 'all' && rowCompany !== company) {
                show = false;
            }

            if (show) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });

        document.getElementById('resultCount').textContent = visibleCount;
        document.getElementById('emptyState').classList.toggle('hidden', visibleCount > 0);
    }

    function resetFilters() {
        document.getElementById('roleFilter').value = 'all';
        document.getElementById('deptFilter').value = 'all';
        document.getElementById('companyFilter').value = 'all';
        applyFilters();
    }
</script>