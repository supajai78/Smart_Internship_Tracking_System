<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-4">
        <a href="/admin/sections"
            class="p-2 rounded-lg bg-white border border-slate-200 text-slate-500 hover:text-slate-700 transition-colors">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
        </a>
        <div class="flex-1">
            <div class="flex items-center gap-3">
                <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded-lg font-mono font-bold">
                    <%= section.code %>
                </span>
                <h1 class="text-2xl font-bold text-slate-900">
                    <%= section.name %>
                </h1>
            </div>
            <p class="text-sm text-slate-500 mt-1">
                <% if (section.major) { %>
                    <span class="text-primary-600">
                        <%= section.major.department ? section.major.department.name : '' %>
                    </span>
                    <span class="mx-2">›</span>
                    <span>
                        <%= section.major.name %>
                    </span>
                    <% } %>
            </p>
        </div>
        <a href="/admin/sections/<%= section._id %>/edit" class="btn btn-secondary">
            <i data-feather="edit-2" class="w-4 h-4"></i>
            แก้ไข
        </a>
    </div>

    <!-- Section Info Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="card p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center text-blue-600">
                    <i data-feather="users" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-slate-900">
                        <%= students.length %>
                    </p>
                    <p class="text-sm text-slate-500">นักศึกษา</p>
                </div>
            </div>
        </div>

        <div class="card p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center text-green-600">
                    <i data-feather="calendar" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-lg font-bold text-slate-900">
                        <% if (section.academicYear) { %>
                            <%= section.academicYear.name %>
                                <% } else { %>
                                    -
                                    <% } %>
                    </p>
                    <p class="text-sm text-slate-500">ปีการศึกษา</p>
                </div>
            </div>
        </div>

        <div class="card p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center text-purple-600">
                    <i data-feather="layers" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-lg font-bold text-slate-900">
                        <% if (section.level) { %>
                            <%= section.level.name %>
                                <% } else { %>
                                    -
                                    <% } %>
                    </p>
                    <p class="text-sm text-slate-500">ระดับชั้น</p>
                </div>
            </div>
        </div>

        <div class="card p-4">
            <div class="flex items-center gap-3">
                <div
                    class="w-10 h-10 rounded-xl <%= section.isActive ? 'bg-green-100 text-green-600' : 'bg-slate-100 text-slate-600' %> flex items-center justify-center">
                    <i data-feather="<%= section.isActive ? 'check-circle' : 'x-circle' %>" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-lg font-bold text-slate-900">
                        <%= section.isActive ? 'เปิดใช้งาน' : 'ปิดใช้งาน' %>
                    </p>
                    <p class="text-sm text-slate-500">สถานะ</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Students List -->
    <div class="card">
        <div class="p-4 border-b border-slate-100">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-bold text-slate-900">
                    <i data-feather="users" class="w-5 h-5 inline text-primary-500"></i>
                    รายชื่อนักศึกษา
                </h2>
                <span class="badge badge-info">
                    <%= students.length %> คน
                </span>
            </div>
        </div>

        <% if (students.length===0) { %>
            <div class="p-12 text-center">
                <div
                    class="w-16 h-16 rounded-full bg-slate-100 mx-auto flex items-center justify-center mb-4 text-slate-400">
                    <i data-feather="user-x" class="w-8 h-8"></i>
                </div>
                <p class="text-slate-500 font-medium">ยังไม่มีนักศึกษาในห้องนี้</p>
                <a href="/admin/users/create" class="btn btn-primary btn-sm mt-4">เพิ่มนักศึกษา</a>
            </div>
            <% } else { %>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="bg-slate-50">
                                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase">#</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase">
                                    รหัสนักศึกษา</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase">
                                    ชื่อ-นามสกุล</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase">อีเมล
                                </th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase">เบอร์โทร
                                </th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase">
                                    สถานประกอบการ</th>
                                <th class="px-4 py-3 text-right text-xs font-semibold text-slate-500 uppercase">จัดการ
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% students.forEach(function(student, index) { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-4 py-3 text-slate-500">
                                        <%= index + 1 %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="font-mono text-sm bg-slate-100 px-2 py-1 rounded">
                                            <%= student.studentId || '-' %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-3">
                                            <div
                                                class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 text-sm font-bold">
                                                <%= student.firstName ? student.firstName.charAt(0) : '?' %>
                                            </div>
                                            <div>
                                                <p class="font-medium text-slate-900">
                                                    <%= student.firstName %>
                                                        <%= student.lastName %>
                                                </p>
                                                <p class="text-xs text-slate-500">@<%= student.username %>
                                                </p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-slate-600">
                                        <%= student.email || '-' %>
                                    </td>
                                    <td class="px-4 py-3 text-slate-600">
                                        <%= student.phone || '-' %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <% if (student.company) { %>
                                            <span class="badge bg-green-100 text-green-700">
                                                <%= student.company.name %>
                                            </span>
                                            <% } else { %>
                                                <span class="text-slate-400">ยังไม่ได้จับคู่</span>
                                                <% } %>
                                    </td>
                                    <td class="px-4 py-3 text-right">
                                        <a href="/admin/users/<%= student._id %>/edit"
                                            class="p-2 rounded-lg text-slate-400 hover:text-blue-600 hover:bg-blue-50 transition-colors inline-block">
                                            <i data-feather="edit-2" class="w-4 h-4"></i>
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } %>
    </div>
</div>