<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-4">
        <a href="/admin/sections"
            class="p-2 rounded-lg bg-white border border-slate-200 text-slate-500 hover:text-slate-700 transition-colors">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-900">เพิ่มห้องเรียน</h1>
            <p class="text-sm text-slate-500">สร้างห้องเรียน/Section ใหม่</p>
        </div>
    </div>

    <!-- Form -->
    <div class="card max-w-2xl">
        <form action="/admin/sections" method="POST" class="space-y-5">

            <!-- ปีการศึกษา -->
            <div>
                <label class="form-label">ปีการศึกษา *</label>
                <select name="academicYear" class="input" required>
                    <option value="">-- เลือกปีการศึกษา --</option>
                    <% academicYears.forEach(y=> { %>
                        <option value="<%= y._id %>" <%=y.isActive ? 'selected' : '' %>><%= y.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <!-- สาขาวิชา -->
            <div>
                <label class="form-label">สาขาวิชา *</label>
                <select name="major" class="input" required>
                    <option value="">-- เลือกสาขาวิชา --</option>
                    <% majors.forEach(m=> { %>
                        <option value="<%= m._id %>">
                            <%= m.name %>
                                <% if(m.department) { %>(<%= m.department.name %>)<% } %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <!-- ระดับชั้น -->
            <div>
                <label class="form-label">ระดับชั้น</label>
                <select name="level" class="input">
                    <option value="">-- เลือกระดับชั้น (ถ้ามี) --</option>
                    <% levels.forEach(l=> { %>
                        <option value="<%= l._id %>">
                            <%= l.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <!-- รหัสห้อง -->
                <div>
                    <label class="form-label">รหัสห้อง *</label>
                    <input type="text" name="code" class="input" placeholder="เช่น IT01-1" required>
                    <p class="form-hint">ตั้งรหัสให้ไม่ซ้ำกัน</p>
                </div>

                <!-- ชื่อห้อง -->
                <div>
                    <label class="form-label">ชื่อห้อง *</label>
                    <input type="text" name="name" class="input" placeholder="เช่น ห้อง 1" required>
                </div>
            </div>

            <!-- รายละเอียด -->
            <div>
                <label class="form-label">รายละเอียดเพิ่มเติม</label>
                <textarea name="description" class="input" rows="2" placeholder="หมายเหตุ (ถ้ามี)"></textarea>
            </div>

            <!-- Buttons -->
            <div class="flex gap-3 pt-4 border-t border-slate-100">
                <button type="submit" class="btn btn-primary">
                    <i data-feather="save" class="w-4 h-4"></i>
                    บันทึก
                </button>
                <a href="/admin/sections" class="btn btn-secondary">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>