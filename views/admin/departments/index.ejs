<div class="space-y-6 animate-fade-in">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-surface-900">จัดการแผนกวิชา</h1>
            <p class="text-surface-500 text-sm">ดูแลและจัดการแผนกวิชาทั้งหมด</p>
        </div>
        <a href="/admin/departments/create" class="btn btn-primary">
            <i data-feather="plus" class="w-4 h-4"></i>
            เพิ่มแผนกวิชา
        </a>
    </div>

    <!-- Department Cards Grid -->
    <% if (departments.length===0) { %>
        <div class="card text-center py-16">
            <div
                class="w-20 h-20 rounded-full bg-surface-100 mx-auto flex items-center justify-center mb-4 text-surface-400">
                <i data-feather="layers" class="w-10 h-10"></i>
            </div>
            <p class="text-surface-500 font-medium">ยังไม่มีแผนกวิชา</p>
            <a href="/admin/departments/create" class="btn btn-primary mt-4">เพิ่มแผนกวิชาแรก</a>
        </div>
        <% } else { %>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <% departments.forEach(item=> { %>
                    <div class="card group hover:border-primary-200 relative overflow-hidden">
                        <!-- Gradient Accent -->
                        <div
                            class="absolute top-0 left-0 w-2 h-full bg-gradient-to-b from-primary-500 to-primary-700 rounded-l-3xl">
                        </div>

                        <div class="pl-4">
                            <!-- Header -->
                            <div class="flex items-start justify-between mb-4">
                                <div>
                                    <span class="text-xs font-bold text-primary-600 bg-primary-50 px-2 py-1 rounded-lg">
                                        <%= item.code %>
                                    </span>
                                    <h3
                                        class="text-lg font-bold text-surface-900 mt-2 group-hover:text-primary-600 transition-colors">
                                        <%= item.name %>
                                    </h3>
                                </div>
                                <span
                                    class="badge-pill <%= item.isActive ? 'bg-green-100 text-green-700' : 'bg-surface-100 text-surface-500' %>">
                                    <%= item.isActive ? 'ใช้งาน' : 'ไม่ใช้งาน' %>
                                </span>
                            </div>

                            <!-- Major Count -->
                            <div class="flex items-center gap-3 p-3 bg-surface-50 rounded-2xl mb-4">
                                <div
                                    class="w-10 h-10 rounded-xl bg-primary-100 text-primary-600 flex items-center justify-center">
                                    <i data-feather="book" class="w-5 h-5"></i>
                                </div>
                                <div>
                                    <p class="text-2xl font-bold text-surface-900">
                                        <%= item.majorCount || 0 %>
                                    </p>
                                    <p class="text-xs text-surface-500">สาขาวิชา</p>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="flex items-center gap-2 pt-4 border-t border-surface-100">
                                <a href="/admin/departments/<%= item._id %>/view"
                                    class="flex-1 btn btn-secondary btn-sm justify-center">
                                    <i data-feather="eye" class="w-4 h-4"></i>
                                    ดูสาขา
                                </a>
                                <a href="/admin/departments/<%= item._id %>/edit"
                                    class="p-2 rounded-xl text-surface-400 hover:text-primary-600 hover:bg-primary-50 transition-colors">
                                    <i data-feather="edit-2" class="w-4 h-4"></i>
                                </a>
                                <form action="/admin/departments/<%= item._id %>/delete" method="POST" class="inline"
                                    onsubmit="return confirmDelete()">
                                    <button type="submit"
                                        class="p-2 rounded-xl text-surface-400 hover:text-red-600 hover:bg-red-50 transition-colors">
                                        <i data-feather="trash-2" class="w-4 h-4"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } %>
</div>