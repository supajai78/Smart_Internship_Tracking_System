<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="/admin/departments" class="text-gray-500 hover:text-gray-700">← กลับ</a>
        <h1 class="text-2xl font-bold text-gray-800">เพิ่มแผนกวิชา</h1>
    </div>

    <div class="card max-w-2xl">
        <form action="/admin/departments" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">รหัสแผนก</label>
                <input type="text" name="code" class="input" placeholder="เช่น IT, AUTO" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">ชื่อแผนกวิชา</label>
                <input type="text" name="name" class="input" placeholder="เช่น แผนกวิชาเทคโนโลยีสารสนเทศ" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">รายละเอียด</label>
                <textarea name="description" class="input" rows="3"></textarea>
            </div>
            <div class="flex items-center gap-2">
                <input type="checkbox" name="isActive" id="isActive" class="w-4 h-4" checked>
                <label for="isActive" class="text-sm text-gray-700">เปิดใช้งาน</label>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="submit" class="btn btn-primary">บันทึก</button>
                <a href="/admin/departments" class="btn btn-outline">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>