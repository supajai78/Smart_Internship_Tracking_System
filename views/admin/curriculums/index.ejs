<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">จัดการหลักสูตร</h1>
        <a href="/admin/curriculums/create" class="btn btn-primary">➕ เพิ่มหลักสูตร</a>
    </div>
    <div class="card">
        <table class="w-full">
            <thead>
                <tr class="text-left border-b">
                    <th class="pb-3 text-gray-600">รหัส</th>
                    <th class="pb-3 text-gray-600">ชื่อหลักสูตร</th>
                    <th class="pb-3 text-gray-600">ระดับชั้น</th>
                    <th class="pb-3 text-gray-600">จำนวนวันฝึกงาน</th>
                    <th class="pb-3 text-gray-600 text-right">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                <% curriculums.forEach(item=> { %>
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 font-mono text-sm">
                            <%= item.code %>
                        </td>
                        <td class="py-3 font-medium">
                            <%= item.name %>
                        </td>
                        <td class="py-3">
                            <%= item.level ? item.level.name : '-' %>
                        </td>
                        <td class="py-3">
                            <%= item.internshipDuration %> วัน
                        </td>
                        <td class="py-3 text-right">
                            <a href="/admin/curriculums/<%= item._id %>/edit"
                                class="text-primary-600 hover:text-primary-800 mr-3">แก้ไข</a>
                            <form action="/admin/curriculums/<%= item._id %>/delete" method="POST" class="inline"
                                onsubmit="return confirmDelete()">
                                <button type="submit" class="text-danger-500 hover:text-danger-700">ลบ</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </div>
</div>