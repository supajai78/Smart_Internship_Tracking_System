<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="/admin/curriculums" class="text-gray-500 hover:text-gray-700">← กลับ</a>
        <h1 class="text-2xl font-bold text-gray-800">เพิ่มหลักสูตร</h1>
    </div>
    <div class="card max-w-2xl">
        <form action="/admin/curriculums" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">รหัสหลักสูตร</label>
                <input type="text" name="code" class="input" placeholder="เช่น pvs-direct, pvs-m6" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">ชื่อหลักสูตร</label>
                <input type="text" name="name" class="input" placeholder="เช่น ปวส. สายตรง" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">ระดับชั้น</label>
                <select name="level" class="input" required>
                    <option value="">-- เลือกระดับชั้น --</option>
                    <% levels.forEach(l=> { %>
                        <option value="<%= l._id %>">
                            <%= l.name %>
                        </option>
                        <% }); %>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันฝึกงาน</label>
                <input type="number" name="internshipDuration" class="input" placeholder="เช่น 60, 120" required
                    min="1">
            </div>
            <div class="flex gap-3 pt-4">
                <button type="submit" class="btn btn-primary">บันทึก</button>
                <a href="/admin/curriculums" class="btn btn-outline">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>