<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="/admin/academic-years" class="text-gray-500 hover:text-gray-700">← กลับ</a>
        <h1 class="text-2xl font-bold text-gray-800">แก้ไขปีการศึกษา</h1>
    </div>

    <div class="card max-w-2xl">
        <form action="/admin/academic-years/<%= academicYear._id %>" method="POST" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">ปี พ.ศ.</label>
                    <input type="number" name="year" class="input" value="<%= academicYear.year %>" required min="2500"
                        max="2600">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">ภาคเรียน</label>
                    <select name="semester" class="input" required>
                        <option value="1" <%=academicYear.semester===1 ? 'selected' : '' %>>ภาคเรียนที่ 1</option>
                        <option value="2" <%=academicYear.semester===2 ? 'selected' : '' %>>ภาคเรียนที่ 2</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">วันเริ่มต้นฝึกงาน</label>
                    <input type="date" name="startDate" class="input"
                        value="<%= academicYear.startDate.toISOString().split('T')[0] %>" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">วันสิ้นสุดฝึกงาน</label>
                    <input type="date" name="endDate" class="input"
                        value="<%= academicYear.endDate.toISOString().split('T')[0] %>" required>
                </div>
            </div>

            <div class="flex items-center gap-2">
                <input type="checkbox" name="isActive" id="isActive" class="w-4 h-4 text-primary-600"
                    <%=academicYear.isActive ? 'checked' : '' %>>
                <label for="isActive" class="text-sm text-gray-700">ตั้งเป็นปีการศึกษาปัจจุบัน</label>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="btn btn-primary">บันทึก</button>
                <a href="/admin/academic-years" class="btn btn-outline">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>