<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="/mentor/students" class="text-gray-500 hover:text-gray-700">← กลับ</a>
        <h1 class="text-2xl font-bold text-gray-800">ข้อมูลนักศึกษา</h1>
    </div>

    <!-- Student Info -->
    <div class="card">
        <div class="flex items-center gap-4 mb-6">
            <div
                class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 font-bold text-2xl">
                <%= student.firstName.charAt(0) %>
            </div>
            <div>
                <h2 class="text-xl font-bold">
                    <%= student.firstName %>
                        <%= student.lastName %>
                </h2>
                <p class="text-gray-500">
                    <%= student.studentId || '' %>
                </p>
            </div>
        </div>

        <div class="grid md:grid-cols-3 gap-4">
            <div>
                <p class="text-sm text-gray-500">สาขาวิชา</p>
                <p class="font-medium">
                    <%= student.major ? student.major.name : '-' %>
                </p>
            </div>
            <div>
                <p class="text-sm text-gray-500">ระดับชั้น</p>
                <p class="font-medium">
                    <%= student.level ? student.level.name : '-' %>
                </p>
            </div>
            <div>
                <p class="text-sm text-gray-500">หลักสูตร</p>
                <p class="font-medium">
                    <%= student.curriculum ? student.curriculum.name : '-' %>
                </p>
            </div>
            <div>
                <p class="text-sm text-gray-500">วันเข้างานรวม</p>
                <p class="font-medium text-green-600">
                    <%= totalAttendance %> วัน
                </p>
            </div>
            <div>
                <p class="text-sm text-gray-500">ครูนิเทศก์</p>
                <p class="font-medium">
                    <%= student.teacher ? student.teacher.firstName + ' ' + student.teacher.lastName : '-' %>
                </p>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="flex gap-3">
        <a href="/mentor/evaluations/<%= student._id %>/create" class="btn btn-primary">⭐ ประเมินนักศึกษา</a>
    </div>

    <!-- Attendance History -->
    <div class="card">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">📅 ประวัติการเข้างาน</h3>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="text-left border-b">
                        <th class="pb-3 text-gray-600">วันที่</th>
                        <th class="pb-3 text-gray-600">เข้างาน</th>
                        <th class="pb-3 text-gray-600">ออกงาน</th>
                        <th class="pb-3 text-gray-600">สถานะ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (attendances.length===0) { %>
                        <tr>
                            <td colspan="4" class="py-8 text-center text-gray-500">ยังไม่มีประวัติ</td>
                        </tr>
                        <% } %>
                            <% attendances.forEach(a=> { %>
                                <tr class="border-b">
                                    <td class="py-3">
                                        <%= new Date(a.date).toLocaleDateString('th-TH') %>
                                    </td>
                                    <td class="py-3">
                                        <% if (a.checkInTime) { %>
                                            <%= new Date(a.checkInTime).toLocaleTimeString('th-TH', { hour: '2-digit' ,
                                                minute: '2-digit' }) %>
                                                <% } else { %>-<% } %>
                                    </td>
                                    <td class="py-3">
                                        <% if (a.checkOutTime) { %>
                                            <%= new Date(a.checkOutTime).toLocaleTimeString('th-TH', { hour: '2-digit' ,
                                                minute: '2-digit' }) %>
                                                <% } else { %>-<% } %>
                                    </td>
                                    <td class="py-3">
                                        <% if (a.status==='present' ) { %>
                                            <span class="status-badge status-success">เข้างาน</span>
                                            <% } else if (a.status==='late' ) { %>
                                                <span class="status-badge bg-yellow-100 text-yellow-700">สาย</span>
                                                <% } else if (a.status==='leave' ) { %>
                                                    <span class="status-badge status-pending">ลา</span>
                                                    <% } else { %>
                                                        <span class="status-badge bg-red-100 text-red-700">ขาด</span>
                                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Daily Logs -->
    <div class="card">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">📝 บันทึกงานล่าสุด</h3>
        <% if (dailyLogs.length===0) { %>
            <p class="text-gray-500 text-center py-4">ยังไม่มีบันทึก</p>
            <% } else { %>
                <div class="space-y-4">
                    <% dailyLogs.forEach(log=> { %>
                        <div class="p-4 bg-gray-50 rounded-lg">
                            <p class="text-sm text-gray-500 mb-2">
                                <%= new Date(log.date).toLocaleDateString('th-TH') %>
                            </p>
                            <p class="text-gray-700">
                                <%= log.workDescription %>
                            </p>
                        </div>
                        <% }); %>
                </div>
                <% } %>
    </div>
</div>