<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">อนุมัติใบลา</h1>
    </div>

    <div class="card">
        <% if (leaveRequests.length===0) { %>
            <div class="text-center py-12">
                <span class="text-4xl mb-4 block">📋</span>
                <p class="text-gray-500">ไม่มีใบลา</p>
            </div>
            <% } else { %>
                <table class="w-full">
                    <thead>
                        <tr class="text-left border-b">
                            <th class="pb-3 text-gray-600">นักศึกษา</th>
                            <th class="pb-3 text-gray-600">ประเภท</th>
                            <th class="pb-3 text-gray-600">วันที่ลา</th>
                            <th class="pb-3 text-gray-600">เหตุผล</th>
                            <th class="pb-3 text-gray-600">สถานะ</th>
                            <th class="pb-3 text-gray-600 text-right">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% leaveRequests.forEach(leave=> { %>
                            <tr class="border-b hover:bg-gray-50">
                                <td class="py-3 font-medium">
                                    <%= leave.student ? leave.student.firstName + ' ' + leave.student.lastName : '-' %>
                                </td>
                                <td class="py-3">
                                    <% if (leave.type==='sick' ) { %>
                                        <span class="status-badge bg-red-100 text-red-700">ลาป่วย</span>
                                        <% } else { %>
                                            <span class="status-badge bg-blue-100 text-blue-700">ลากิจ</span>
                                            <% } %>
                                </td>
                                <td class="py-3 text-sm">
                                    <%= new Date(leave.startDate).toLocaleDateString('th-TH') %>
                                        <% if (new Date(leave.startDate).getTime() !==new Date(leave.endDate).getTime())
                                            { %>
                                            - <%= new Date(leave.endDate).toLocaleDateString('th-TH') %>
                                                <% } %>
                                </td>
                                <td class="py-3 text-sm text-gray-600 max-w-xs truncate">
                                    <%= leave.reason %>
                                </td>
                                <td class="py-3">
                                    <% if (leave.status==='pending' ) { %>
                                        <span class="status-badge status-pending">รออนุมัติ</span>
                                        <% } else if (leave.status==='approved' ) { %>
                                            <span class="status-badge status-success">อนุมัติ</span>
                                            <% } else { %>
                                                <span class="status-badge bg-red-100 text-red-700">ไม่อนุมัติ</span>
                                                <% } %>
                                </td>
                                <td class="py-3 text-right">
                                    <% if (leave.status==='pending' ) { %>
                                        <form action="/mentor/leave-requests/<%= leave._id %>/approve" method="POST"
                                            class="inline">
                                            <button type="submit" class="text-green-600 hover:text-green-800 mr-2">✅
                                                อนุมัติ</button>
                                        </form>
                                        <form action="/mentor/leave-requests/<%= leave._id %>/reject" method="POST"
                                            class="inline">
                                            <button type="submit" class="text-red-600 hover:text-red-800">❌
                                                ไม่อนุมัติ</button>
                                        </form>
                                        <% } else { %>
                                            <span class="text-gray-400 text-sm">
                                                โดย <%= leave.approvedBy ? leave.approvedBy.firstName : '-' %>
                                            </span>
                                            <% } %>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% } %>
    </div>
</div>