<div class="space-y-8 animate-fade-in">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-display font-bold text-surface-900">สวัสดี, <%= mentor.firstName %>! 👋</h1>
            <p class="text-surface-500 font-medium mt-1">
                พี่เลี้ยงประจำ <span class="text-surface-900 font-bold">
                    <%= mentor.company ? mentor.company.name : '-' %>
                </span>
            </p>
        </div>
        <!-- <div class="flex gap-3">
      <button class="btn btn-secondary">
        <i data-feather="settings" class="w-4 h-4"></i>
        <span>ตั้งค่า</span>
      </button>
    </div> -->
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Students Count -->
        <div class="widget group hover:bg-gradient-to-br hover:from-blue-500 hover:to-blue-600 hover:text-white transition-all cursor-pointer"
            onclick="window.location='/mentor/students'">
            <div class="relative z-10">
                <p class="text-sm font-bold text-surface-500 group-hover:text-blue-100 uppercase tracking-widest mb-1">
                    นักศึกษาในสังกัด</p>
                <p class="text-4xl font-display font-bold text-surface-900 group-hover:text-white">
                    <%= stats.studentCount %>
                </p>
                <div
                    class="mt-4 flex items-center gap-2 text-sm text-blue-600 group-hover:text-white font-bold opacity-0 group-hover:opacity-100 transition-opacity transform translate-y-2 group-hover:translate-y-0">
                    <span>ดูรายชื่อ</span>
                    <i data-feather="arrow-right" class="w-4 h-4"></i>
                </div>
            </div>
            <div
                class="w-16 h-16 rounded-3xl bg-blue-50 text-blue-500 flex items-center justify-center group-hover:bg-white/20 group-hover:text-white transition-colors">
                <i data-feather="users" class="w-8 h-8"></i>
            </div>
        </div>

        <!-- Padding Leaves -->
        <div class="widget group hover:bg-gradient-to-br hover:from-yellow-500 hover:to-amber-600 hover:text-white transition-all cursor-pointer"
            onclick="window.location='/mentor/leave-requests'">
            <div class="relative z-10">
                <p
                    class="text-sm font-bold text-surface-500 group-hover:text-yellow-100 uppercase tracking-widest mb-1">
                    ใบลารออนุมัติ</p>
                <p class="text-4xl font-display font-bold text-surface-900 group-hover:text-white">
                    <%= stats.pendingLeaves %>
                </p>
                <div
                    class="mt-4 flex items-center gap-2 text-sm text-yellow-600 group-hover:text-white font-bold opacity-0 group-hover:opacity-100 transition-opacity transform translate-y-2 group-hover:translate-y-0">
                    <span>จัดการใบลา</span>
                    <i data-feather="arrow-right" class="w-4 h-4"></i>
                </div>
            </div>
            <div
                class="w-16 h-16 rounded-3xl bg-yellow-50 text-yellow-500 flex items-center justify-center group-hover:bg-white/20 group-hover:text-white transition-colors">
                <i data-feather="file-text" class="w-8 h-8"></i>
            </div>
        </div>

        <!-- Attendance -->
        <div class="widget">
            <div class="relative z-10">
                <p class="text-sm font-bold text-surface-500 uppercase tracking-widest mb-1">เข้างานวันนี้</p>
                <div class="flex items-baseline gap-2">
                    <p class="text-4xl font-display font-bold text-surface-900">
                        <%= stats.todayAttendance %>
                    </p>
                    <span class="text-surface-400 font-medium text-lg">/ <%= stats.studentCount %></span>
                </div>
                <div class="mt-4 w-full bg-surface-100 rounded-full h-2 overflow-hidden">
                    <div class="bg-green-500 h-2 rounded-full"
                        style="width: <%= stats.todayAttendance / (stats.studentCount || 1) * 100 %>%"></div>
                </div>
            </div>
            <div class="w-16 h-16 rounded-3xl bg-green-50 text-green-500 flex items-center justify-center">
                <i data-feather="clock" class="w-8 h-8"></i>
            </div>
        </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
        <!-- Student List -->
        <div class="card lg:col-span-2">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold text-surface-900 flex items-center gap-2">
                    <i data-feather="users" class="w-5 h-5 text-primary-500"></i>
                    นักศึกษาล่าสุด
                </h3>
                <a href="/mentor/students" class="text-sm font-bold text-primary-600 hover:text-primary-700">ดูทั้งหมด
                    -></a>
            </div>

            <% if (students.length> 0) { %>
                <div class="space-y-4">
                    <% students.forEach(s=> { %>
                        <div class="group flex items-center gap-4 p-4 rounded-3xl bg-surface-50 border border-transparent hover:border-primary-200 hover:bg-white hover:shadow-card transition-all cursor-pointer"
                            onclick="window.location='/mentor/students/<%= s._id %>'">
                            <div
                                class="w-14 h-14 rounded-2xl bg-white flex items-center justify-center text-xl font-bold text-primary-600 shadow-sm group-hover:bg-primary-500 group-hover:text-white transition-colors">
                                <%= s.firstName.charAt(0) %>
                            </div>
                            <div class="flex-1 min-w-0">
                                <h4 class="font-bold text-surface-900 truncate">
                                    <%= s.firstName %>
                                        <%= s.lastName %>
                                </h4>
                                <p class="text-sm text-surface-500 truncate">
                                    <%= s.studentId || '-' %> • <%= s.major ? s.major.name : '' %>
                                </p>
                            </div>
                            <div
                                class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-surface-400 group-hover:text-primary-500 transition-colors shadow-sm">
                                <i data-feather="chevron-right" class="w-5 h-5"></i>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } else { %>
                    <div class="text-center py-12">
                        <p class="text-surface-400">ยังไม่มีนักศึกษาในสังกัด</p>
                    </div>
                    <% } %>
        </div>

        <!-- Quick Menu -->
        <div class="card bg-surface-900 text-white border-none shadow-xl">
            <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
                <i data-feather="zap" class="w-5 h-5 text-yellow-500"></i>
                เมนูด่วน
            </h3>

            <div class="space-y-3">
                <a href="/mentor/students"
                    class="flex items-center gap-4 p-4 rounded-2xl bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/5">
                    <div class="w-10 h-10 rounded-xl bg-blue-500/20 text-blue-300 flex items-center justify-center">
                        <i data-feather="user" class="w-5 h-5"></i>
                    </div>
                    <span class="font-bold">ข้อมูลนักศึกษา</span>
                </a>

                <a href="/mentor/leave-requests"
                    class="flex items-center gap-4 p-4 rounded-2xl bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/5">
                    <div class="w-10 h-10 rounded-xl bg-yellow-500/20 text-yellow-300 flex items-center justify-center">
                        <i data-feather="check-square" class="w-5 h-5"></i>
                    </div>
                    <span class="font-bold">อนุมัติการลา</span>
                </a>

                <a href="/mentor/evaluations"
                    class="flex items-center gap-4 p-4 rounded-2xl bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/5">
                    <div class="w-10 h-10 rounded-xl bg-purple-500/20 text-purple-300 flex items-center justify-center">
                        <i data-feather="star" class="w-5 h-5"></i>
                    </div>
                    <span class="font-bold">ประเมินผล</span>
                </a>
            </div>
        </div>
    </div>
</div>