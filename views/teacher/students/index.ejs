<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">นักศึกษาในความดูแล</h1>
    </div>

    <div class="card">
        <% if (students.length===0) { %>
            <div class="text-center py-12">
                <span class="text-4xl mb-4 block">👨‍🎓</span>
                <p class="text-gray-500">ยังไม่มีนักศึกษาในความดูแล</p>
            </div>
            <% } else { %>
                <table class="w-full">
                    <thead>
                        <tr class="text-left border-b">
                            <th class="pb-3 text-gray-600">ชื่อ-นามสกุล</th>
                            <th class="pb-3 text-gray-600">รหัส</th>
                            <th class="pb-3 text-gray-600">สาขา</th>
                            <th class="pb-3 text-gray-600">สถานประกอบการ</th>
                            <th class="pb-3 text-gray-600 text-right">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% students.forEach(s=> { %>
                            <tr class="border-b hover:bg-gray-50">
                                <td class="py-3">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 font-medium">
                                            <%= s.firstName.charAt(0) %>
                                        </div>
                                        <span class="font-medium">
                                            <%= s.firstName %>
                                                <%= s.lastName %>
                                        </span>
                                    </div>
                                </td>
                                <td class="py-3 font-mono text-sm">
                                    <%= s.studentId || '-' %>
                                </td>
                                <td class="py-3">
                                    <%= s.major ? s.major.name : '-' %>
                                </td>
                                <td class="py-3">
                                    <%= s.company ? s.company.name : '-' %>
                                </td>
                                <td class="py-3 text-right">
                                    <a href="/teacher/students/<%= s._id %>"
                                        class="text-primary-600 hover:text-primary-800 mr-3">ดูรายละเอียด</a>
                                    <a href="/teacher/evaluations/<%= s._id %>/create"
                                        class="text-yellow-600 hover:text-yellow-800">⭐ ประเมิน</a>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% } %>
    </div>
</div>