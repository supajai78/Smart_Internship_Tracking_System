<div class="space-y-8 animate-fade-in">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-display font-bold text-surface-900">สวัสดี, <%= teacher.firstName %>! 👋</h1>
            <% if (teacher.department) { %>
                <p class="text-surface-500 font-medium mt-1">
                    ครูนิเทศก์ประจำแผนก <span class="text-surface-900 font-bold">
                        <%= teacher.department.name %>
                    </span>
                </p>
                <% } %>
        </div>
        <div class="flex gap-3">
            <a href="/teacher/supervisions/create" class="btn btn-primary shadow-xl shadow-primary-500/20">
                <i data-feather="clipboard" class="w-4 h-4"></i>
                <span>บันทึกการนิเทศ</span>
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="widget group hover:-translate-y-1 transition-transform">
            <div>
                <p class="text-sm font-bold text-surface-500 uppercase tracking-widest mb-1">นักศึกษาในความดูแล</p>
                <p class="text-3xl font-display font-bold text-surface-900">
                    <%= stats.studentCount %>
                </p>
            </div>
            <div
                class="w-14 h-14 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                <i data-feather="users" class="w-7 h-7"></i>
            </div>
        </div>

        <div class="widget group hover:-translate-y-1 transition-transform">
            <div>
                <p class="text-sm font-bold text-surface-500 uppercase tracking-widest mb-1">เข้างานวันนี้</p>
                <p class="text-3xl font-display font-bold text-green-600">
                    <%= stats.presentToday %><span class="text-lg text-surface-400 font-medium">/<%= stats.studentCount
                                %></span>
                </p>
            </div>
            <div
                class="w-14 h-14 rounded-2xl bg-green-50 text-green-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                <i data-feather="check-circle" class="w-7 h-7"></i>
            </div>
        </div>

        <div class="widget group hover:-translate-y-1 transition-transform cursor-pointer border-purple-200 bg-purple-50/30"
            onclick="window.location='/teacher/weekly-reports'">
            <div>
                <p class="text-sm font-bold text-surface-500 uppercase tracking-widest mb-1">รายงานรอตรวจ</p>
                <p class="text-3xl font-display font-bold text-purple-600">
                    <%= stats.pendingReports %>
                </p>
            </div>
            <div
                class="w-14 h-14 rounded-2xl bg-purple-100 text-purple-600 flex items-center justify-center group-hover:scale-110 transition-transform shadow-sm">
                <i data-feather="file-text" class="w-7 h-7"></i>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid lg:grid-cols-3 gap-8">

        <!-- Student Status List -->
        <div class="lg:col-span-2 card">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold text-surface-900 flex items-center gap-2">
                    <i data-feather="clock" class="w-5 h-5 text-primary-500"></i>
                    สถานะนักศึกษาวันนี้
                </h3>
                <div class="flex gap-2 text-xs font-bold">
                    <span class="flex items-center gap-1 bg-green-50 text-green-700 px-2 py-1 rounded-lg"><span
                            class="w-2 h-2 rounded-full bg-green-500"></span> เข้างาน</span>
                    <span class="flex items-center gap-1 bg-yellow-50 text-yellow-700 px-2 py-1 rounded-lg"><span
                            class="w-2 h-2 rounded-full bg-yellow-500"></span> กำลังทำ</span>
                    <span class="flex items-center gap-1 bg-red-50 text-red-700 px-2 py-1 rounded-lg"><span
                            class="w-2 h-2 rounded-full bg-red-500"></span> ขาด/ลา</span>
                </div>
            </div>

            <% if (students.length===0) { %>
                <div class="text-center py-12 border-2 border-dashed border-surface-200 rounded-3xl">
                    <p class="text-surface-500 font-medium">ยังไม่มีนักศึกษาในความดูแล</p>
                </div>
                <% } else { %>
                    <div class="grid gap-3">
                        <% students.forEach(s=> { %>
                            <a href="/teacher/students/<%= s._id %>"
                                class="flex items-center gap-4 p-4 rounded-2xl border border-surface-100 hover:border-primary-200 hover:shadow-md transition-all group bg-white">
                                <div class="relative">
                                    <div
                                        class="w-12 h-12 rounded-xl bg-surface-100 flex items-center justify-center text-primary-600 font-bold group-hover:bg-primary-50 transition-colors">
                                        <%= s.firstName.charAt(0) %>
                                    </div>
                                    <div
                                        class="absolute -bottom-1 -right-1 w-4 h-4 border-2 border-white rounded-full <%= s.todayStatus === 'complete' ? 'bg-green-500' : s.todayStatus === 'working' ? 'bg-yellow-500' : 'bg-red-500' %>">
                                    </div>
                                </div>

                                <div class="flex-1 min-w-0">
                                    <p class="font-bold text-surface-900 truncate">
                                        <%= s.firstName %>
                                            <%= s.lastName %>
                                    </p>
                                    <p class="text-xs text-surface-500 truncate mt-0.5">
                                        <%= s.company ? s.company.name : 'ยังไม่มีบริษัท' %>
                                    </p>
                                </div>

                                <div class="text-surface-300 group-hover:text-primary-500 transition-colors">
                                    <i data-feather="chevron-right" class="w-5 h-5"></i>
                                </div>
                            </a>
                            <% }); %>
                    </div>
                    <% } %>
        </div>

        <!-- Quick Actions Vertical -->
        <div class="space-y-6">
            <div class="card bg-surface-900 text-white border-none shadow-xl relative overflow-hidden">
                <div
                    class="absolute top-0 right-0 w-32 h-32 bg-primary-500 rounded-full blur-[60px] opacity-20 transform translate-x-10 -translate-y-10">
                </div>

                <h3 class="text-lg font-bold mb-4 relative z-10">เมนูด่วน</h3>
                <div class="space-y-3 relative z-10">
                    <a href="/teacher/students"
                        class="flex items-center gap-3 p-3 rounded-xl bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/5">
                        <div class="p-2 rounded-lg bg-blue-500/20 text-blue-300"><i data-feather="users"
                                class="w-4 h-4"></i></div>
                        <span class="font-medium">ข้อมูลนักศึกษา</span>
                    </a>
                    <a href="/teacher/supervisions"
                        class="flex items-center gap-3 p-3 rounded-xl bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/5">
                        <div class="p-2 rounded-lg bg-green-500/20 text-green-300"><i data-feather="clipboard"
                                class="w-4 h-4"></i></div>
                        <span class="font-medium">บันทึกนิเทศ</span>
                    </a>
                    <a href="/teacher/weekly-reports"
                        class="flex items-center gap-3 p-3 rounded-xl bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/5">
                        <div class="p-2 rounded-lg bg-purple-500/20 text-purple-300"><i data-feather="file-text"
                                class="w-4 h-4"></i></div>
                        <span class="font-medium">ตรวจรายงาน</span>
                    </a>
                    <a href="/teacher/evaluations"
                        class="flex items-center gap-3 p-3 rounded-xl bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/5">
                        <div class="p-2 rounded-lg bg-yellow-500/20 text-yellow-300"><i data-feather="star"
                                class="w-4 h-4"></i></div>
                        <span class="font-medium">ประเมินผล</span>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>