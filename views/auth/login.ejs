        <!-- Abstract Pattern -->
        <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
            <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
                <path fill="currentColor" d="M0 0 L100 0 L100 100 Z" />
            </svg>
            <div class="absolute top-10 right-10 w-64 h-64 bg-white rounded-full blur-3xl opacity-20"></div>
            <div class="absolute bottom-10 left-10 w-96 h-96 bg-primary-900 rounded-full blur-3xl opacity-30"></div>
        </div>

        <!-- Content -->
        <div class="relative z-10 text-center md:text-left max-w-lg">
            <div
                class="w-20 h-20 md:w-24 md:h-24 bg-white/10 backdrop-blur-lg rounded-2xl flex items-center justify-center mb-8 mx-auto md:mx-0 shadow-2xl border border-white/20">
                <span class="text-4xl md:text-5xl">🎓</span>
            </div>

            <h1 class="text-3xl md:text-5xl font-extrabold mb-4 tracking-tight leading-tight">
                Smart Internship <br />
                <span class="text-primary-200">Tracking System</span>
            </h1>

            <p class="text-lg md:text-xl text-primary-100 mb-8 font-light">
                ระบบติดตามและประเมินผลการฝึกงานอัจฉริยะ เชื่อมโยงนักศึกษา สถานประกอบการ และอาจารย์เข้าด้วยกัน
            </p>

            <div class="grid grid-cols-2 gap-4 text-sm opacity-80">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center">✓</div>
                    <span>GPS Check-in</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center">✓</div>
                    <span>Online Report</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center">✓</div>
                    <span>Real-time Stats</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center">✓</div>
                    <span>Fast Approval</span>
                </div>
            </div>
        </div>

        <p class="absolute bottom-4 text-primary-300 text-xs md:hidden">
            © 2024 Smart Internship
        </p>
    </div>

    <!-- Right Side: Login Form (White - Trailing/Form) -->
    <div class="md:w-1/2 bg-white flex items-center justify-center p-8 md:p-12 order-1 md:order-2">
        <div class="w-full max-w-md space-y-8">

            <div class="text-center md:text-left">
                <h2 class="text-3xl font-bold text-gray-900">ยินดีต้อนรับกลับ!</h2>
                <p class="text-gray-500 mt-2">กรุณาเข้าสู่ระบบเพื่อดำเนินการต่อ</p>
            </div>

            <form action="/auth/login" method="POST" class="space-y-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">ชื่อผู้ใช้</label>
                        <div class="relative group">
                            <span
                                class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary-600 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </span>
                            <input type="text" name="username"
                                class="input pl-11 bg-gray-50 border-gray-200 focus:bg-white" placeholder="Username"
                                required autofocus>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">รหัสผ่าน</label>
                        <div class="relative group">
                            <span
                                class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary-600 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                </svg>
                            </span>
                            <input type="password" name="password"
                                class="input pl-11 bg-gray-50 border-gray-200 focus:bg-white" placeholder="••••••••"
                                required>
                        </div>
                        <!-- <div class="flex justify-end mt-1">
              <a href="#" class="text-xs text-primary-600 hover:text-primary-700">ลืมรหัสผ่าน?</a>
            </div> -->
                    </div>
                </div>

                <button type="submit"
                    class="btn btn-primary w-full py-3 text-lg shadow-lg hover:shadow-xl hover:translate-y-[-2px] transition-all">
                    เข้าสู่ระบบ
                </button>

                <!-- Divider -->
                <div class="relative">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-gray-200"></div>
                    </div>
                    <div class="relative flex justify-center text-sm">
                        <span class="px-2 bg-white text-gray-500">บัญชีทดสอบ</span>
                    </div>
                </div>

                <!-- Demo Accounts -->
                <div class="grid grid-cols-2 gap-3">
                    <button type="button" onclick="fillLogin('admin', 'admin123')"
                        class="flex flex-col items-center p-3 border border-gray-200 rounded-xl hover:border-primary-500 hover:bg-primary-50 transition-all cursor-pointer group">
                        <span class="text-xs font-bold text-gray-600 group-hover:text-primary-700">Admin</span>
                        <span class="text-[10px] text-gray-400">admin / admin123</span>
                    </button>
                    <button type="button" onclick="fillLogin('teacher01', 'teacher123')"
                        class="flex flex-col items-center p-3 border border-gray-200 rounded-xl hover:border-primary-500 hover:bg-primary-50 transition-all cursor-pointer group">
                        <span class="text-xs font-bold text-gray-600 group-hover:text-primary-700">Teacher</span>
                        <span class="text-[10px] text-gray-400">teacher01 / teacher123</span>
                    </button>
                    <button type="button" onclick="fillLogin('mentor01', 'mentor123')"
                        class="flex flex-col items-center p-3 border border-gray-200 rounded-xl hover:border-primary-500 hover:bg-primary-50 transition-all cursor-pointer group">
                        <span class="text-xs font-bold text-gray-600 group-hover:text-primary-700">Mentor</span>
                        <span class="text-[10px] text-gray-400">mentor01 / mentor123</span>
                    </button>
                    <button type="button" onclick="fillLogin('student01', 'student123')"
                        class="flex flex-col items-center p-3 border border-gray-200 rounded-xl hover:border-primary-500 hover:bg-primary-50 transition-all cursor-pointer group">
                        <span class="text-xs font-bold text-gray-600 group-hover:text-primary-700">Student</span>
                        <span class="text-[10px] text-gray-400">student01 / student123</span>
                    </button>
                </div>
            </form>

            <p class="text-center text-xs text-gray-400 mt-8">
                © 2024 Smart Internship Tracking System<br />
                Designed for Excellence
            </p>
        </div>
    </div>
</div>

<script>
    function fillLogin(u, p) {
        document.querySelector('input[name="username"]').value = u;
        document.querySelector('input[name="password"]').value = p;
    }
</script>